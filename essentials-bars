            except Exception as e:
                print(f"[bars] weather: {e}")
        l = Gtk.Label(label="󰖐"); l.set_name("bar-stat"); return l

    # ── Per-core CPU ──────────────────────────────────────────────────────────
    def _w_percore(self):
        box  = Gtk.Box(spacing=2); box.set_name("percore-box")
        n    = min(psutil.cpu_count(logical=True) or 4, 8)
        bars = []
        for _ in range(n):
            bar = Gtk.ProgressBar()
            bar.set_name("core-bar")
            bar.set_orientation(Gtk.Orientation.VERTICAL)
            bar.set_inverted(True)
            bar.set_fraction(0)
            bar.set_size_request(4, 22)
            box.pack_start(bar, False, False, 0)
            bars.append(bar)

        def upd():
            try:
                for i, (bar, pct) in enumerate(
                        zip(bars, psutil.cpu_percent(percpu=True))):
                    bar.set_fraction(pct / 100)
                box.set_tooltip_text("  ".join(
                    f"C{i}:{int(p)}%" for i, p in
                    enumerate(psutil.cpu_percent(percpu=True))))
            except: pass

        self._defer(upd); self._repeat(2000, upd)
        return box

