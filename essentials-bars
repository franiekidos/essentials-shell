def _win_css(bg, border, radius):
    return f"""
        window {{
            background-color: {bg};
            border:           {border};
            border-radius:    {radius};
        }}
    """.encode()


def _build_trilands():
    """3 floating pill windows."""
    bg = T.get("bg","rgba(17,17,27,0.92)")

    class TriBar(Gtk.Window):
        def __init__(self, pos):
            Gtk.Window.__init__(self)
            GtkLayerShell.init_for_window(self)
            GtkLayerShell.set_layer(self, GtkLayerShell.Layer.TOP)
            GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.TOP, True)
            GtkLayerShell.set_margin(self, GtkLayerShell.Edge.TOP, 8)
            # Keep all trilands windows on the same vertical geometry track.
            GtkLayerShell.set_exclusive_zone(self, -1)
            if pos == "left":
                GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.LEFT, True)
                GtkLayerShell.set_margin(self, GtkLayerShell.Edge.LEFT, 12)
            elif pos == "center":
                pass
            elif pos == "right":
                GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.RIGHT, True)
                GtkLayerShell.set_margin(self, GtkLayerShell.Edge.RIGHT, 12)
            box = Gtk.Box(spacing=8)
            box.set_margin_start(14); box.set_margin_end(14)
            box.set_margin_top(6);    box.set_margin_bottom(6)
            self.add(box); _fill(box, pos)
            self.show_all()
            if AUTOHIDE: _setup_autohide(self)

    for pos in ("left","center","right"):
        TriBar(pos)

    p = Gtk.CssProvider()
    p.load_from_data(_win_css(bg, "1px solid rgba(255,255,255,0.07)", "999px"))
    return p


def _build_islands():
    """1 compact centred pill, all sections merged."""
    win = Gtk.Window()
    GtkLayerShell.init_for_window(win)
    GtkLayerShell.set_layer(win, GtkLayerShell.Layer.TOP)
    GtkLayerShell.set_exclusive_zone(win, 46)
    GtkLayerShell.set_anchor(win, GtkLayerShell.Edge.TOP, True)
    GtkLayerShell.set_margin(win, GtkLayerShell.Edge.TOP, 10)

    box = Gtk.Box(spacing=14)
    box.set_margin_start(20); box.set_margin_end(20)
    box.set_margin_top(6);    box.set_margin_bottom(6)
    win.add(box)

    f = WidgetFactory()
    for i, section in enumerate(("left","center","right")):
        for wid in LAYOUT.get(section, []):
            w = f.build(wid)
            if w: box.pack_start(w, False, False, 0)
        if i < 2:
            sep = Gtk.Label(label="·"); sep.set_name("bar-sep-dot")
            box.pack_start(sep, False, False, 4)

    win.show_all()
    if AUTOHIDE: _setup_autohide(win)

    bg = T.get("bg","rgba(17,17,27,0.92)")
    p  = Gtk.CssProvider()
    p.load_from_data((f"""
        window {{
            background-color: {bg};
            border: 1px solid {T.get('accent','#cba6f7')};
            border-radius: 999px;
        }}
        #bar-sep-dot {{ color: rgba(255,255,255,0.20); font-size: 16px; }}
    """).encode())
    return p


def _build_still():
    """Full-width flat classic taskbar, opaque, flush to edge."""
    win = Gtk.Window()
    GtkLayerShell.init_for_window(win)
    GtkLayerShell.set_layer(win, GtkLayerShell.Layer.TOP)
    GtkLayerShell.set_exclusive_zone(win, 40)
    for edge in (GtkLayerShell.Edge.TOP,
                 GtkLayerShell.Edge.LEFT, GtkLayerShell.Edge.RIGHT):
        GtkLayerShell.set_anchor(win, edge, True)

    root = Gtk.Box(spacing=0)
    root.set_margin_start(12); root.set_margin_end(12)
    win.add(root)

    left_box   = Gtk.Box(); left_box.set_margin_top(4); left_box.set_margin_bottom(4)
    center_box = Gtk.Box(); center_box.set_margin_top(4); center_box.set_margin_bottom(4)
    right_box  = Gtk.Box(); right_box.set_margin_top(4); right_box.set_margin_bottom(4)
    _fill(left_box, "left", 10); _fill(center_box, "center", 10); _fill(right_box, "right", 10)

    root.pack_start(left_box,   False, False, 0)
    root.set_center_widget(center_box)
    root.pack_end(right_box,    False, False, 0)
    win.show_all()
    if AUTOHIDE: _setup_autohide(win, zone=40)

    raw = T.get("bg","rgba(17,17,27,0.92)")
    m   = re.match(r"rgba\((\d+),\s*(\d+),\s*(\d+)", raw)
    opaque = f"rgb({m.group(1)},{m.group(2)},{m.group(3)})" if m else raw

    p = Gtk.CssProvider()
    p.load_from_data(f"""
        window {{
            background-color: {opaque}; border: none;
            border-bottom: 1px solid rgba(255,255,255,0.07); border-radius: 0;
        }}
    """.encode())
    return p


def _build_floating():
