CONFIG_PATH = os.path.expanduser("~/.config/essentials/config.json")
THEME_PATH  = os.path.expanduser("~/.config/essentials/themes.json")
BIN         = os.path.expanduser("~/.local/bin")
DONE_FLAG   = os.path.expanduser("~/.config/essentials/.wizard_done")

# ── Compositor abstraction ────────────────────────────────────────────────────
def _load_wm():
    path = os.path.join(BIN, "essentials-detect")
    if os.path.exists(path):
        try:
            loader = importlib.machinery.SourceFileLoader("essentials_detect", path)
            spec   = importlib.util.spec_from_loader("essentials_detect", loader)
            mod    = importlib.util.module_from_spec(spec)
            loader.exec_module(mod)
            return mod.detect()
        except Exception as e:
            print(f"[bars] detect: {e}")
    class _FB:
        name = "generic"
        def get_active_workspace(self): return 1
        def get_workspace_count(self):  return 4
        def get_config_path(self):      return None
    return _FB()

WM = _load_wm()

# ── Config + theme ────────────────────────────────────────────────────────────
def _load_config():
    try:
        with open(CONFIG_PATH) as f: return json.load(f)
    except: return {}

def _load_theme():
    try:
        data = json.load(open(THEME_PATH))
        cur  = data.get("current", "catppuccin")
        return data.get(cur, data.get("catppuccin", {}))
    except:
        return {"bg":"rgba(17,17,27,0.92)","accent":"#cba6f7",
                "text":"#cdd6f4","radius":"10px"}

CFG        = _load_config()
T          = _load_theme()
STYLE_NAME = CFG.get("bar_style", "trilands")
AUTOHIDE   = CFG.get("bar_autohide", False)
LAYOUT     = CFG.get("bar", {
    "left":   ["launcher","wm-badge","workspaces"],
    "center": ["media","clock"],
    "right":  ["network","cpu","ram","cc-button"],
})

def _run(*cmd, fallback=""):
    try:    return subprocess.check_output(
                list(cmd), text=True, stderr=subprocess.DEVNULL).strip()
    except: return fallback

def _popen(*cmd):
    try:    subprocess.Popen(list(cmd), stderr=subprocess.DEVNULL)
    except Exception as e: print(f"[bars] popen {cmd[0]}: {e}")

def _hex_from_rgba(raw):
    """rgba(r,g,b,...) → 'rrggbb' string, or None."""
    m = re.match(r"rgba\((\d+),\s*(\d+),\s*(\d+)", raw)
    return "{:02x}{:02x}{:02x}".format(
        int(m.group(1)), int(m.group(2)), int(m.group(3))) if m else None

# ── Widget factory ────────────────────────────────────────────────────────────
class WidgetFactory:
    """
    Builds bar widgets. All data updates deferred via idle_add / timeout_add
    so nothing blocks during window construction.
    """

    @staticmethod
    def _defer(fn):
        def _cb():
            try:    fn()
            except Exception as e: print(f"[bar widget] {e}")
            return False
        GLib.idle_add(_cb)

    @staticmethod
    def _repeat(ms, fn):
        def _tick():
            try:    fn()
            except Exception as e: print(f"[bar widget] {e}")
            return True
        GLib.idle_add(lambda: (GLib.timeout_add(ms, _tick), False)[1])

    def build(self, wid):
        fn = getattr(self, "_w_" + wid.replace("-","_"), None)
        return fn() if fn else None

    # ── Launcher ──────────────────────────────────────────────────────────────
    def _w_launcher(self):
        b = Gtk.Button(label="󰣇"); b.set_name("bar-launcher")
        b.set_tooltip_text("App launcher")
        b.connect("clicked", lambda _: _popen("python3", f"{BIN}/essentials-launcher"))
        return b

    # ── WM badge ──────────────────────────────────────────────────────────────
    def _w_wm_badge(self):
        l = Gtk.Label(label=WM.name[:5].upper()); l.set_name("wm-badge")
        l.set_tooltip_text(f"Compositor: {WM.name}")
        return l

    # ── Workspaces (scroll wheel switches) ────────────────────────────────────
    def _w_workspaces(self):
        if WM.name not in ("hyprland","niri","sway"):
            return None
        box = Gtk.Box(spacing=5); box.set_name("ws-box")
        box.add_events(Gdk.EventMask.SCROLL_MASK)

        def _switch(direction):
            if WM.name == "hyprland":
                cmd = ["hyprctl","dispatch",
                       "workspace","e+1" if direction > 0 else "e-1"]
                subprocess.run(cmd, stderr=subprocess.DEVNULL)
            elif WM.name == "sway":
                subprocess.run(
                    ["swaymsg","workspace","next" if direction > 0 else "prev"],
                    stderr=subprocess.DEVNULL)

        def on_scroll(w, event):
            if event.direction == Gdk.ScrollDirection.DOWN: _switch(1)
            elif event.direction == Gdk.ScrollDirection.UP:  _switch(-1)
            elif event.direction == Gdk.ScrollDirection.SMOOTH:
                if event.delta_y > 0: _switch(1)
                elif event.delta_y < 0: _switch(-1)

        box.connect("scroll-event", on_scroll)

        def upd():
            for c in box.get_children(): box.remove(c)
            try:    active, count = WM.get_active_workspace(), WM.get_workspace_count()
            except: active, count = 1, 4
            for i in range(1, min(count+1, 10)):
                l = Gtk.Label(label="󰮯" if i==active else "󰊠")
                l.set_name("ws-active" if i==active else "ws-idle")
                box.pack_start(l, False, False, 0)
            box.show_all()

        self._defer(upd); self._repeat(500, upd)
        return box

    # ── Clock (updates every second, tooltip shows date) ──────────────────────
    def _w_clock(self):
        l = Gtk.Label(); l.set_name("bar-clock")
        def upd():
            now = datetime.datetime.now()
            l.set_text(now.strftime("󰥔 %H:%M"))
            l.set_tooltip_text(now.strftime("%A, %d %B %Y"))
        self._defer(upd); self._repeat(1000, upd)
        return l

    # ── Date ──────────────────────────────────────────────────────────────────
    def _w_date(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            l.set_text(datetime.datetime.now().strftime("󰃭 %d %b"))
        self._defer(upd); self._repeat(60000, upd)
        return l

    # ── Media (click opens CC, tooltip shows full title) ──────────────────────
    def _w_media(self):
        btn = Gtk.Button(); btn.set_name("bar-media-btn")
        lbl = Gtk.Label(); lbl.set_name("bar-media")
        btn.add(lbl)
        btn.connect("clicked", lambda _: _popen("python3", f"{BIN}/essentials-cc"))

        def upd():
            title = _run("playerctl","metadata","title")
            if title:
                status = _run("playerctl","status", fallback="Stopped")
                icon   = "󰏤" if status == "Playing" else "󰐊"
                short  = title[:26] + ("…" if len(title)>26 else "")
                lbl.set_text(f"{icon} {short}")
                btn.set_tooltip_text(f"{title}  [{_run('playerctl','metadata','artist')}]")
            else:
                lbl.set_text("")
                btn.set_tooltip_text("")

        self._defer(upd); self._repeat(2000, upd)
        return btn

    # ── CPU (click opens CC) ──────────────────────────────────────────────────
    def _w_cpu(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        l.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        l.connect("button-press-event",
                  lambda *_: _popen("python3", f"{BIN}/essentials-cc"))
        def upd():
            pct = int(psutil.cpu_percent())
            l.set_text(f"󰍛 {pct}%")
            l.set_tooltip_text(f"CPU: {pct}%  ({psutil.cpu_count()} cores)")
        self._defer(upd); self._repeat(3000, upd)
        return l

    # ── RAM (tooltip with detail) ─────────────────────────────────────────────
    def _w_ram(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            vm  = psutil.virtual_memory()
            pct = int(vm.percent)
            used_gb = vm.used / 1e9
            total_gb= vm.total / 1e9
            l.set_text(f"󰘚 {pct}%")
            l.set_tooltip_text(f"RAM: {used_gb:.1f} / {total_gb:.1f} GB")
        self._defer(upd); self._repeat(5000, upd)
        return l

    # ── Temp ──────────────────────────────────────────────────────────────────
    def _w_temp(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            try:
                temps = psutil.sensors_temperatures()
                # Prefer coretemp/k10temp/cpu_thermal
                for key in ("coretemp","k10temp","cpu_thermal","acpitz"):
                    if key in temps:
                        t = temps[key][0].current
                        high = temps[key][0].high or 90
                        l.set_text(f"󰔏 {int(t)}°")
                        l.set_name("bar-stat-warn" if t > high*0.85 else "bar-stat")
                        l.set_tooltip_text(f"CPU temp: {t:.1f}°C  (high: {high}°C)")
                        return
                l.set_text("")
            except: l.set_text("")
        self._defer(upd); self._repeat(10000, upd)
        return l

    # ── Disk ──────────────────────────────────────────────────────────────────
    def _w_disk(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            try:
                du  = psutil.disk_usage("/")
                pct = int(du.percent)
                free_gb = du.free / 1e9
                l.set_text(f"󰋊 {pct}%")
                l.set_name("bar-stat-warn" if pct > 85 else "bar-stat")
                l.set_tooltip_text(f"Disk: {free_gb:.0f} GB free")
            except: l.set_text("")
        self._defer(upd); self._repeat(30000, upd)
        return l

    # ── Battery (color changes near empty) ────────────────────────────────────
    def _w_battery(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            try:
                b = psutil.sensors_battery()
                if not b: l.set_text(""); return
                pct = int(b.percent)
                if b.power_plugged:
                    icon = "󰂄"; style = "bar-stat"
                elif pct <= 10:
                    icon = "󰁺"; style = "bar-stat-crit"
                elif pct <= 25:
                    icon = "󰁻"; style = "bar-stat-warn"
                elif pct <= 50:
                    icon = "󰁽"; style = "bar-stat"
                elif pct <= 75:
                    icon = "󰂀"; style = "bar-stat"
                else:
                    icon = "󰁹"; style = "bar-stat"
                l.set_text(f"{icon} {pct}%")
                l.set_name(style)
                secs = b.secsleft
                if secs > 0 and not b.power_plugged:
                    h, m = divmod(secs//60, 60)
                    l.set_tooltip_text(f"Battery: {pct}%  ~{h}h{m:02d}m remaining")
                else:
                    l.set_tooltip_text(f"Battery: {pct}%  {'charging' if b.power_plugged else ''}")
            except: l.set_text("")
        self._defer(upd); self._repeat(30000, upd)
        return l

    # ── Network (click opens CC) ──────────────────────────────────────────────
    def _w_network(self):
        l = Gtk.Label(); l.set_name("bar-net")
        l.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        l.connect("button-press-event",
                  lambda *_: _popen("python3", f"{BIN}/essentials-cc"))
        def upd():
            # Try nmcli wifi
            out   = _run("nmcli","-t","-f","active,ssid","dev","wifi")
            ssids = [x.split(":")[1] for x in out.splitlines() if x.startswith("yes:")]
            if ssids:
                l.set_text(f"󰖩 {ssids[0][:14]}")
                l.set_tooltip_text(f"WiFi: {ssids[0]}")
                return
            # Try wired
            eth = _run("nmcli","-t","-f","type,state","dev")
            for line in eth.splitlines():
                if "ethernet" in line and "connected" in line:
                    l.set_text("󰈀 Wired"); l.set_tooltip_text("Ethernet connected"); return
            l.set_text("󰖪")
            l.set_tooltip_text("Not connected")
        self._defer(upd); self._repeat(10000, upd)
        return l

    # ── Volume (scroll wheel adjusts) ─────────────────────────────────────────
    def _w_volume(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        l.add_events(Gdk.EventMask.SCROLL_MASK | Gdk.EventMask.BUTTON_PRESS_MASK)

        def _get_vol():
            out = _run("wpctl","get-volume","@DEFAULT_AUDIO_SINK@")
            try:
                muted = "[MUTED]" in out
                val   = int(float(out.split(":")[1].strip().split()[0]) * 100)
                return val, muted
            except: return 50, False

        def _osd(val):
            osd = os.path.join(BIN, "essentials-osd")
            if os.path.exists(osd):
                _popen("python3", osd, "volume", str(val))

        def upd():
            val, muted = _get_vol()
            if muted:
                l.set_text("󰝟"); l.set_tooltip_text("Muted")
            else:
                icon = "󰕾" if val > 50 else "󰖀" if val > 0 else "󰕿"
                l.set_text(f"{icon} {val}%"); l.set_tooltip_text(f"Volume: {val}%")

        def on_scroll(w, event):
            d = 0
            if event.direction == Gdk.ScrollDirection.UP:   d =  5
            elif event.direction == Gdk.ScrollDirection.DOWN: d = -5
            elif event.direction == Gdk.ScrollDirection.SMOOTH:
                if event.delta_y < 0: d =  5
                elif event.delta_y > 0: d = -5
            if d:
                cmd = "5%+" if d > 0 else "5%-"
                subprocess.run(["wpctl","set-volume","-l","1.0",
                                 "@DEFAULT_AUDIO_SINK@", cmd],
                               stderr=subprocess.DEVNULL)
                val, _ = _get_vol()
                _osd(val)
                upd()

        def on_click(w, event):
            if event.button == 1:
                subprocess.run(["wpctl","set-mute","@DEFAULT_AUDIO_SINK@","toggle"],
                               stderr=subprocess.DEVNULL)
                upd()

        l.connect("scroll-event",       on_scroll)
        l.connect("button-press-event", on_click)
        self._defer(upd); self._repeat(5000, upd)
        return l

    # ── Updates ───────────────────────────────────────────────────────────────
    def _w_updates(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            for chk, fmt in [
                (["checkupdates"],
                 lambda o: (f"󰚰 {len(o.splitlines())}", len(o.splitlines()))),
                (["apt","list","--upgradable"],
                 lambda o: (f"󰚰 {max(0,len(o.splitlines())-1)}", max(0,len(o.splitlines())-1))),
            ]:
                out = _run(*chk)
                if out:
                    text, count = fmt(out)
                    l.set_text(text)
                    l.set_name("bar-stat-warn" if count > 20 else "bar-stat")
                    l.set_tooltip_text(f"{count} updates available")
                    return
            l.set_text("")
        self._defer(upd); self._repeat(300000, upd)
        return l

