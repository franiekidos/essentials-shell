    }}
    #bar-cc-btn:hover, #bar-pwr-btn:hover {{ background-color: rgba(255,255,255,0.12); }}
""".encode())

screen = Gdk.Screen.get_default()
Gtk.StyleContext.add_provider_for_screen(
    screen, shared_css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

# ── First-run wizard ─────────────────────────────────────────────────────────
DONE_FLAG = os.path.expanduser("~/.config/essentials/.wizard_done")
if not os.path.exists(DONE_FLAG):
    subprocess.Popen(["python3", f"{BIN}/essentials-wizard"])
    # Wizard launches bars itself on finish — exit here
    import sys; sys.exit(0)

# ── Auto-start widgets if configured ─────────────────────────────────────────
_wcfg = CFG.get("widgets", {})
if _wcfg.get("enabled"):
    subprocess.Popen(["python3", f"{BIN}/essentials-widgets"])

# ── Restore wallpaper ─────────────────────────────────────────────────────────
_wall = CFG.get("wallpaper")
if _wall and os.path.exists(_wall):
    import shutil as _sh
    for _tool, _cmd in [
        ("swww",     ["swww","img",_wall,"--transition-type","fade"]),
        ("swaybg",   ["swaybg","-i",_wall,"-m","fill"]),
        ("hyprpaper",["hyprctl","hyprpaper","wallpaper",f",{_wall}"]),
        ("feh",      ["feh","--bg-fill",_wall]),
        ("wbg",      ["wbg",_wall]),
    ]:
        if _sh.which(_tool):
            subprocess.Popen(_cmd, stderr=subprocess.DEVNULL)
            break

# ── Launch chosen style ───────────────────────────────────────────────────────
builders = {
    "trilands": _build_trilands,
    "islands":  _build_islands,
    "still":    _build_still,
    "floating": _build_floating,
    "blocks":   _build_blocks,
}

style_css = builders.get(STYLE_NAME, _build_trilands)()

# Apply the per-style window CSS at a higher priority than the shared sheet
if style_css:
    Gtk.StyleContext.add_provider_for_screen(
        screen, style_css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION + 1)

Gtk.main()
