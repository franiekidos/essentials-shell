#!/usr/bin/env python3
"""
essentials-bars

Five genuinely distinct bar styles:

  trilands  – 3 separate floating pill windows  (default)
  islands   – 1 small centered floating window (all sections merged, compact)
  still     – 1 full-width edge-to-edge flat bar (classic taskbar, opaque)
  floating  – 1 full-width floating bar with side margins (rounded, semi-transparent)
  blocks    – 3 rectangular windows anchored to the BOTTOM of the screen
"""
import gi, os, json, subprocess, importlib.util, psutil, datetime, re
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, GtkLayerShell, GLib, Gdk

CONFIG_PATH = os.path.expanduser("~/.config/essentials/config.json")
BIN         = os.path.expanduser("~/.local/bin")

# ── Compositor abstraction ────────────────────────────────────────────────────
def _load_wm():
    path = os.path.expanduser("~/.local/bin/essentials-detect")
    if os.path.exists(path):
        try:
            spec = importlib.util.spec_from_file_location("essentials_detect", path)
            if spec and spec.loader:
                mod = importlib.util.module_from_spec(spec)
                spec.loader.exec_module(mod)
                return mod.detect()
        except Exception as e:
            print(f"[bars] detect failed: {e}")
    class _FB:
        name = "generic"
        def get_active_workspace(self): return 1
        def get_workspace_count(self):  return 4
    return _FB()

WM = _load_wm()

# ── Config + theme ────────────────────────────────────────────────────────────
def _load_config():
    try:
        with open(CONFIG_PATH) as f: return json.load(f)
    except: return {}

def _load_theme():
    try:
        data    = json.load(open(os.path.expanduser("~/.config/essentials/themes.json")))
        current = data.get("current", "catppuccin")
        return data.get(current, data.get("catppuccin", {}))
    except:
        return {"bg":"rgba(17,17,27,0.92)","accent":"#cba6f7",
                "text":"#cdd6f4","radius":"10px"}

CFG    = _load_config()
T      = _load_theme()
LAYOUT = CFG.get("bar", {
    "left":   ["launcher","wm-badge","workspaces"],
    "center": ["media","clock"],
    "right":  ["network","cpu","ram","cc-button"],
})

STYLE_NAME = CFG.get("bar_style", "trilands")

def _run(*cmd, fallback=""):
    try:    return subprocess.check_output(list(cmd), text=True,
                                           stderr=subprocess.DEVNULL).strip()
    except: return fallback

def _coerce_bg(base, alpha):
    if alpha is None: return base
    m = re.match(r"rgba\((\d+),\s*(\d+),\s*(\d+)", base)
    if m: return f"rgba({m.group(1)},{m.group(2)},{m.group(3)},{alpha})"
    return base

# ── Widget factory ────────────────────────────────────────────────────────────
# All widget updates are deferred via GLib.idle_add — nothing runs
# synchronously during window construction to prevent re-entrancy / recursion.

class WidgetFactory:
    @staticmethod
    def _defer(fn):
        """Run fn() once after the main loop starts. Never repeats."""
        def _cb():
            try: fn()
            except Exception as e: print(f"[bar] {e}")
            return False   # explicit False — one shot
        GLib.idle_add(_cb)

    @staticmethod
    def _repeat(ms, fn):
        """Run fn() on a recurring timer, first tick deferred until after show_all."""
        def _tick():
            try: fn()
            except Exception as e: print(f"[bar] {e}")
            return True    # explicit True — keep repeating
        def _start():
            GLib.timeout_add(ms, _tick)
            return False   # explicit False — idle fires once then stops
        GLib.idle_add(_start)

    def build(self, wid):
        fn = getattr(self, "_w_" + wid.replace("-","_"), None)
        return fn() if fn else None

    def _w_launcher(self):
        b = Gtk.Button(label="󰣇"); b.set_name("bar-launcher")
        b.connect("clicked", lambda _: subprocess.Popen(["python3",f"{BIN}/essentials-launcher"]))
        return b

    def _w_wm_badge(self):
        l = Gtk.Label(label=WM.name[:5].upper()); l.set_name("wm-badge"); return l

    def _w_workspaces(self):
        if WM.name not in ("hyprland","niri","sway"): return None
        box = Gtk.Box(spacing=5); box.set_name("ws-box")
        def upd():
            for c in box.get_children(): box.remove(c)
            try:    active, count = WM.get_active_workspace(), WM.get_workspace_count()
            except: active, count = 1, 4
            for i in range(1, min(count+1, 10)):
                l = Gtk.Label(label="󰮯" if i==active else "󰊠")
                l.set_name("ws-active" if i==active else "ws-idle")
                box.pack_start(l, False, False, 0)
            box.show_all()
        self._defer(upd); self._repeat(500, upd); return box

    def _w_clock(self):
        l = Gtk.Label(); l.set_name("bar-clock")
        def upd(): l.set_text(datetime.datetime.now().strftime("󰥔 %H:%M"))
        self._defer(upd); self._repeat(5000, upd); return l

    def _w_media(self):
        l = Gtk.Label(); l.set_name("bar-media")
        def upd():
            title = _run("playerctl","metadata","title")
            if title:
                icon = "󰏤" if _run("playerctl","status") == "Playing" else "󰐊"
                l.set_text(f"{icon} {title[:22]}{'…' if len(title)>22 else ''}")
            else:
                l.set_text("")
        self._defer(upd); self._repeat(2000, upd); return l

    def _w_cpu(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd(): l.set_text(f"󰍛 {int(psutil.cpu_percent())}%")
        self._defer(upd); self._repeat(3000, upd); return l

    def _w_ram(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd(): l.set_text(f"󰘚 {int(psutil.virtual_memory().percent)}%")
        self._defer(upd); self._repeat(5000, upd); return l

    def _w_temp(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            try:
                t = next(iter(psutil.sensors_temperatures().values()))[0].current
                l.set_text(f"󰔏 {int(t)}°")
            except: l.set_text("")
        self._defer(upd); self._repeat(10000, upd); return l

    def _w_disk(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            try:    l.set_text(f"󰋊 {int(psutil.disk_usage('/').percent)}%")
            except: l.set_text("")
        self._defer(upd); self._repeat(30000, upd); return l

    def _w_battery(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            try:
                b = psutil.sensors_battery()
                if b:
                    icon = "󰂄" if b.power_plugged else ("󰁹" if b.percent>20 else "󰁺")
                    l.set_text(f"{icon} {int(b.percent)}%")
                else: l.set_text("")
            except: l.set_text("")
        self._defer(upd); self._repeat(30000, upd); return l

    def _w_network(self):
        l = Gtk.Label(); l.set_name("bar-net")
        def upd():
            out   = _run("nmcli","-t","-f","active,ssid","dev","wifi")
            ssids = [x.split(":")[1] for x in out.splitlines() if x.startswith("yes:")]
            l.set_text(f"󰖩 {ssids[0][:12]}" if ssids else "󰖪")
        self._defer(upd); self._repeat(10000, upd); return l

    def _w_updates(self):
        l = Gtk.Label(); l.set_name("bar-stat")
        def upd():
            for chk, fmt in [
                (["checkupdates"],             lambda o: f"󰚰 {len(o.splitlines())}"),
                (["apt","list","--upgradable"],lambda o: f"󰚰 {max(0,len(o.splitlines())-1)}"),
            ]:
                out = _run(*chk)
                if out: l.set_text(fmt(out)); return
            l.set_text("")
        self._defer(upd); self._repeat(300000, upd); return l

    def _w_cc_button(self):
        b = Gtk.Button(label="󰒓"); b.set_name("bar-cc-btn")
        b.connect("clicked", lambda _: subprocess.Popen(["python3",f"{BIN}/essentials-cc"]))
        return b

    def _w_power_button(self):
        b = Gtk.Button(label="󰐥"); b.set_name("bar-pwr-btn")
        b.connect("clicked", lambda _: subprocess.Popen(["python3",f"{BIN}/essentials-powermenu"]))
        return b

    def _w_separator(self):
        l = Gtk.Label(label="│"); l.set_name("bar-sep"); return l

    def _w_tray(self): return None

    def _w_lock(self):
        b = Gtk.Button(label="󰌾"); b.set_name("bar-pwr-btn")
        b.set_tooltip_text("Lock screen")
        b.connect("clicked", lambda _: subprocess.Popen(
            ["python3", f"{BIN}/essentials-lockscreen"]))
        return b

    def _w_wallpaper(self):
        b = Gtk.Button(label="󰋩"); b.set_name("bar-cc-btn")
        b.set_tooltip_text("Wallpaper manager")
        b.connect("clicked", lambda _: subprocess.Popen(
            ["python3", f"{BIN}/essentials-wallpaper"]))
        return b


def _fill(box, section, spacing=8):
    f = WidgetFactory()
    for wid in LAYOUT.get(section, []):
        w = f.build(wid)
        if w: box.pack_start(w, False, False, 0)


# ── Style: trilands ───────────────────────────────────────────────────────────
# 3 separate floating pill windows anchored top-left / top-center / top-right

def _build_trilands():
    bg = T.get("bg","rgba(17,17,27,0.92)")
    css_extra = "border-radius: 999px;"

    class TriBar(Gtk.Window):
        def __init__(self, pos):
            Gtk.Window.__init__(self)
            GtkLayerShell.init_for_window(self)
            GtkLayerShell.set_layer(self, GtkLayerShell.Layer.TOP)
            GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.TOP, True)
            GtkLayerShell.set_margin(self, GtkLayerShell.Edge.TOP, 8)
            if pos == "left":
                GtkLayerShell.set_exclusive_zone(self, 46)
                GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.LEFT, True)
                GtkLayerShell.set_margin(self, GtkLayerShell.Edge.LEFT, 12)
            elif pos == "center":
                GtkLayerShell.set_exclusive_zone(self, -1)
            elif pos == "right":
                GtkLayerShell.set_exclusive_zone(self, -1)
                GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.RIGHT, True)
                GtkLayerShell.set_margin(self, GtkLayerShell.Edge.RIGHT, 12)
            box = Gtk.Box(spacing=8)
            box.set_margin_start(14); box.set_margin_end(14)
            self.add(box); _fill(box, pos); self.show_all()

    for pos in ("left","center","right"):
        TriBar(pos)

    p = Gtk.CssProvider()
    p.load_from_data(f"""
        window {{
            background-color: {bg};
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 999px;
        }}
    """.encode())
    return p


# ── Style: islands ────────────────────────────────────────────────────────────
# 1 small centered window — compact, all widgets in a single pill, no left/right split

def _build_islands():
    win = Gtk.Window()
    GtkLayerShell.init_for_window(win)
    GtkLayerShell.set_layer(win, GtkLayerShell.Layer.TOP)
    GtkLayerShell.set_exclusive_zone(win, 46)
    GtkLayerShell.set_anchor(win, GtkLayerShell.Edge.TOP, True)
    GtkLayerShell.set_margin(win, GtkLayerShell.Edge.TOP, 10)
    # No left/right anchor — compositor centres it

    box = Gtk.Box(spacing=16)
    box.set_margin_start(20); box.set_margin_end(20)
    win.add(box)

    # Render all three sections inline with separators between them
    f = WidgetFactory()
    sections = ["left","center","right"]
    for i, section in enumerate(sections):
        for wid in LAYOUT.get(section, []):
            w = f.build(wid)
            if w: box.pack_start(w, False, False, 0)
        if i < len(sections) - 1:
            sep = Gtk.Label(label="·"); sep.set_name("bar-sep-dot")
            box.pack_start(sep, False, False, 4)

    win.show_all()

    p = Gtk.CssProvider()
    bg = T.get("bg","rgba(17,17,27,0.92)")
    p.load_from_data(f"""
        window {{
            background-color: {bg};
            border: 1px solid {T.get('accent','#cba6f7')};
            border-radius: 999px;
        }}
        #bar-sep-dot {{
            color: rgba(255,255,255,0.20);
            font-size: 16px;
        }}
    """.encode())
    return p


# ── Style: still ─────────────────────────────────────────────────────────────
# 1 full-width edge-to-edge flat bar, opaque — classic taskbar

def _build_still():
    win = Gtk.Window()
    GtkLayerShell.init_for_window(win)
    GtkLayerShell.set_layer(win, GtkLayerShell.Layer.TOP)
    GtkLayerShell.set_exclusive_zone(win, 40)
    for edge in (GtkLayerShell.Edge.TOP, GtkLayerShell.Edge.LEFT,
                 GtkLayerShell.Edge.RIGHT):
        GtkLayerShell.set_anchor(win, edge, True)
    # No top margin — flush to screen edge

    root = Gtk.Box(spacing=0)
    root.set_margin_start(12); root.set_margin_end(12)
    win.add(root)

    left_box   = Gtk.Box(spacing=10); _fill(left_box,   "left",   10)
    center_box = Gtk.Box(spacing=10); _fill(center_box, "center", 10)
    right_box  = Gtk.Box(spacing=10); _fill(right_box,  "right",  10)

    root.pack_start(left_box,   False, False, 0)
    root.set_center_widget(center_box)
    root.pack_end(right_box,    False, False, 0)
    win.show_all()

    # Opaque bg derived from theme — strip alpha
    raw_bg = T.get("bg","rgba(17,17,27,0.92)")
    m = re.match(r"rgba\((\d+),\s*(\d+),\s*(\d+)", raw_bg)
    opaque = f"rgb({m.group(1)},{m.group(2)},{m.group(3)})" if m else raw_bg

    p = Gtk.CssProvider()
    p.load_from_data(f"""
        window {{
            background-color: {opaque};
            border: none;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            border-radius: 0;
        }}
    """.encode())
    return p


# ── Style: floating ───────────────────────────────────────────────────────────
# 1 full-width floating bar with side margins — rounded, semi-transparent

def _build_floating():
    win = Gtk.Window()
    GtkLayerShell.init_for_window(win)
    GtkLayerShell.set_layer(win, GtkLayerShell.Layer.TOP)
    GtkLayerShell.set_exclusive_zone(win, 46)
    for edge in (GtkLayerShell.Edge.TOP, GtkLayerShell.Edge.LEFT,
                 GtkLayerShell.Edge.RIGHT):
        GtkLayerShell.set_anchor(win, edge, True)
    GtkLayerShell.set_margin(win, GtkLayerShell.Edge.TOP,   8)
    GtkLayerShell.set_margin(win, GtkLayerShell.Edge.LEFT,  20)
    GtkLayerShell.set_margin(win, GtkLayerShell.Edge.RIGHT, 20)

    root = Gtk.Box(spacing=0)
    root.set_margin_start(16); root.set_margin_end(16)
    win.add(root)

    left_box   = Gtk.Box(spacing=10); _fill(left_box,   "left",   10)
    center_box = Gtk.Box(spacing=10); _fill(center_box, "center", 10)
    right_box  = Gtk.Box(spacing=10); _fill(right_box,  "right",  10)

    root.pack_start(left_box,   False, False, 0)
    root.set_center_widget(center_box)
    root.pack_end(right_box,    False, False, 0)
    win.show_all()

    p = Gtk.CssProvider()
    bg = T.get("bg","rgba(17,17,27,0.92)")
    p.load_from_data(f"""
        window {{
            background-color: {bg};
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 12px;
        }}
    """.encode())
    return p


# ── Style: blocks ─────────────────────────────────────────────────────────────
# 3 rectangular windows anchored to the BOTTOM of the screen

def _build_blocks():
    raw_bg = T.get("bg","rgba(17,17,27,0.92)")
    m = re.match(r"rgba\((\d+),\s*(\d+),\s*(\d+)", raw_bg)
    opaque = f"rgba({m.group(1)},{m.group(2)},{m.group(3)},0.98)" if m else raw_bg

    class BlockBar(Gtk.Window):
        def __init__(self, pos):
            Gtk.Window.__init__(self)
            GtkLayerShell.init_for_window(self)
            GtkLayerShell.set_layer(self, GtkLayerShell.Layer.TOP)
            # Anchor to BOTTOM instead of top
            GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.BOTTOM, True)
            GtkLayerShell.set_margin(self, GtkLayerShell.Edge.BOTTOM, 6)
            if pos == "left":
                GtkLayerShell.set_exclusive_zone(self, 46)
                GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.LEFT, True)
                GtkLayerShell.set_margin(self, GtkLayerShell.Edge.LEFT, 8)
            elif pos == "center":
                GtkLayerShell.set_exclusive_zone(self, -1)
            elif pos == "right":
                GtkLayerShell.set_exclusive_zone(self, -1)
                GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.RIGHT, True)
                GtkLayerShell.set_margin(self, GtkLayerShell.Edge.RIGHT, 8)
            box = Gtk.Box(spacing=6)
            box.set_margin_start(10); box.set_margin_end(10)
            self.add(box); _fill(box, pos); self.show_all()

    for pos in ("left","center","right"):
        BlockBar(pos)

    p = Gtk.CssProvider()
    accent = T.get("accent","#cba6f7")
    p.load_from_data(f"""
        window {{
            background-color: {opaque};
            border: 2px solid {accent};
            border-radius: 6px;
        }}
    """.encode())
    return p


