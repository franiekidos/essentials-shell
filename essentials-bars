        font-family: 'JetBrainsMono Nerd Font', monospace;
        color: {t};
    }}
    window {{
        min-height: 36px;
    }}
    #bar-launcher {{
        background-color: transparent; border: none;
        color: {a}; font-size: 20px; padding: 2px 6px;
    }}
    #bar-launcher:hover {{
        background-color: rgba(255,255,255,0.08); border-radius: 8px;
    }}
    #wm-badge {{
        background-color: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.10); border-radius: 5px;
        font-size: 9px; font-weight: bold; color: {s}; padding: 2px 5px;
    }}
    #ws-active {{ color: {a}; font-size: 14px; }}
    #ws-idle   {{ color: rgba(255,255,255,0.20); font-size: 14px; }}
    #bar-clock {{ font-size: 13px; font-weight: bold; }}
    #bar-media-btn {{
        background-color: transparent; border: none; padding: 0 4px;
    }}
    #bar-media-btn:hover {{
        background-color: rgba(255,255,255,0.06); border-radius: 8px;
    }}
    #bar-media {{ font-size: 12px; color: {s}; }}
    #bar-stat  {{ font-size: 12px; color: {s}; }}
    #bar-stat-warn {{ font-size: 12px; color: {warn_col}; font-weight: bold; }}
    #bar-stat-crit {{ font-size: 12px; color: {crit_col}; font-weight: bold; }}
    #bar-net   {{ font-size: 12px; color: {s}; }}
    #bar-sep   {{ font-size: 14px; color: rgba(255,255,255,0.15); margin: 0 4px; }}
