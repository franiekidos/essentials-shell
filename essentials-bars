#!/usr/bin/env python3
"""
essentials-bars  —  Essentials Shell bar

Five bar styles:
  trilands  – 3 floating pills (default)
  islands   – 1 compact centred pill
  still     – full-width flat classic taskbar
  floating  – full-width floating bar with side margins
  blocks    – 3 rectangular windows at the BOTTOM

Config:  ~/.config/essentials/config.json
  bar_style   : trilands | islands | still | floating | blocks
  bar_autohide: true | false
  bar         : { left:[…], center:[…], right:[…] }

Available widget IDs:
  launcher · wm-badge · workspaces · clock · date · media
  cpu · ram · temp · disk · battery · network · volume
  updates · weather · percore · clipboard
  cc-button · power-button · lock · wallpaper · separator
"""
import gi, os, sys, json, subprocess, importlib.util, psutil, datetime, re, shutil
