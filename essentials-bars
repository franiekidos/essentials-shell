# ── Box filler ────────────────────────────────────────────────────────────────
def _fill(box, section, spacing=8):
    f = WidgetFactory()
    box.set_spacing(spacing)
    for wid in LAYOUT.get(section, []):
        w = f.build(wid)
        if w: box.pack_start(w, False, False, 0)


# ── Auto-hide ─────────────────────────────────────────────────────────────────
def _setup_autohide(win, zone=46):
    GtkLayerShell.set_exclusive_zone(win, 0)
    state = {"timer": None, "hidden": False}

    def _hide():
        if not state["hidden"]:
            child = win.get_child()
            if child: child.hide()
            state["hidden"] = True
        return False

    def _show():
        child = win.get_child()
        if child: child.show_all()
        GtkLayerShell.set_exclusive_zone(win, zone)
        state["hidden"] = False

    def on_enter(w, _e):
        if state["timer"]:
            GLib.source_remove(state["timer"])
            state["timer"] = None
        _show()

    def on_leave(w, _e):
        state["timer"] = GLib.timeout_add(1500, _hide)

    win.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK |
                   Gdk.EventMask.LEAVE_NOTIFY_MASK)
    win.connect("enter-notify-event", on_enter)
    win.connect("leave-notify-event", on_leave)
    GLib.timeout_add(2500, _hide)


# ── Shared CSS ────────────────────────────────────────────────────────────────
def _shared_css():
    a  = T.get("accent", "#cba6f7")
    t  = T.get("text",   "#cdd6f4")
    s  = T.get("subtext", t)

    # Derive warning/critical from theme accent hue
    import colorsys
    def _hex(r,g,b): return "#{:02x}{:02x}{:02x}".format(int(r*255),int(g*255),int(b*255))
    def _parse(h):
        h = h.lstrip("#")
        return int(h[0:2],16)/255, int(h[2:4],16)/255, int(h[4:6],16)/255
    ar,ag,ab = _parse(a)
    hh,hs,hv = colorsys.rgb_to_hsv(ar,ag,ab)
    warn_col  = _hex(*colorsys.hsv_to_rgb(0.11,  max(0.6,hs), min(1,hv*1.1)))  # orange-ish
    crit_col  = _hex(*colorsys.hsv_to_rgb(0.0,   max(0.7,hs), min(1,hv*1.1)))  # red-ish

    return f"""
