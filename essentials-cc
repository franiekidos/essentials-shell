        GLib.timeout_add(2000, self._update_media)

    def _spawn_osd(self, kind, value):
        osd_path = os.path.expanduser("~/.local/bin/essentials-osd")
        if not os.path.exists(osd_path):
            return
        # Ensure only one OSD instance is alive at a time.
        subprocess.run(["pkill", "-f", "essentials-osd"], stderr=subprocess.DEVNULL)
        subprocess.Popen(
            ["python3", osd_path, kind, str(value)],
            stderr=subprocess.DEVNULL,
        )

    def _queue_osd(self, kind, value):
        # Throttle updates so OSD responds immediately, without process spam.
        attr = "_osd_vol_timer" if kind == "volume" else "_osd_bri_timer"
        timer_id = getattr(self, attr)
        now = time.monotonic()
        min_gap = 0.15  # 150ms between OSD spawns
        elapsed = now - self._osd_last_emit.get(kind, 0.0)

        if elapsed >= min_gap:
            if timer_id:
                GLib.source_remove(timer_id)
                setattr(self, attr, None)
            self._osd_pending[kind] = None
            self._osd_last_emit[kind] = now
            self._spawn_osd(kind, value)
            return

        self._osd_pending[kind] = value
        if timer_id:
            return

        wait_ms = max(1, int((min_gap - elapsed) * 1000))

        def _emit():
            pending = self._osd_pending.get(kind)
            setattr(self, attr, None)
            if pending is None:
                return False
            self._osd_pending[kind] = None
            self._osd_last_emit[kind] = time.monotonic()
            self._spawn_osd(kind, pending)
            return False

        setattr(self, attr, GLib.timeout_add(wait_ms, _emit))

    # ── Separator ─────────────────────────────────────────────────────────────
    def _sep(self):
        s = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        s.set_name("cc-sep"); return s

    # ── Section label ─────────────────────────────────────────────────────────
    def _section_lbl(self, text):
        l = Gtk.Label(label=text); l.set_halign(Gtk.Align.START)
        l.set_name("section-lbl"); return l

    # ── Stats row ─────────────────────────────────────────────────────────────
    def _build_stats(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)

        # Top row: main stats
        box = Gtk.Box(spacing=10, homogeneous=True)
        self.cpu_lbl  = self._stat_card(box, "󰍛", "CPU")
        self.ram_lbl  = self._stat_card(box, "󰘚", "RAM")
        self.disk_lbl = self._stat_card(box, "󰋊", "DISK")
        self.temp_lbl = self._stat_card(box, "󰔏", "TEMP")
        outer.pack_start(box, False, False, 0)

        # Per-core CPU row
        core_count = len(psutil.cpu_percent(percpu=True))
        if core_count <= 16:  # only show if manageable
            core_box = Gtk.Box(spacing=3)
            core_box.set_name("core-row")
            self._core_bars = []
            for i in range(core_count):
                vb = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                bar = Gtk.ProgressBar()
                bar.set_orientation(Gtk.Orientation.VERTICAL)
                bar.set_inverted(True)
                bar.set_fraction(0)
                bar.set_name("core-bar")
                lbl = Gtk.Label(label=str(i)); lbl.set_name("core-lbl")
                vb.pack_start(bar, True,  True,  0)
                vb.pack_start(lbl, False, False, 0)
                core_box.pack_start(vb, True, True, 0)
                self._core_bars.append(bar)
            outer.pack_start(core_box, False, False, 0)

        return outer

    def _stat_card(self, box, icon, name):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        card.set_name("stat-card")
        i = Gtk.Label(label=icon); i.set_name("stat-icon")
        v = Gtk.Label(label="--");  v.set_name("stat-val")
        n = Gtk.Label(label=name);  n.set_name("stat-name")
        card.pack_start(i, False, False, 0)
        card.pack_start(v, False, False, 0)
        card.pack_start(n, False, False, 0)
        box.pack_start(card, True, True, 0)
        return v

    def _update_stats(self):
        self.cpu_lbl.set_text(f"{int(psutil.cpu_percent())}%")
        self.ram_lbl.set_text(f"{int(psutil.virtual_memory().percent)}%")
        try:
            u = psutil.disk_usage("/")
            self.disk_lbl.set_text(f"{int(u.percent)}%")
        except:
            self.disk_lbl.set_text("--")
        if HAS["sensors"]:
            try:
                temps = psutil.sensors_temperatures()
                t = next(iter(temps.values()))[0].current
                self.temp_lbl.set_text(f"{int(t)}°")
            except:
                self.temp_lbl.set_text("--")
        else:
            self.temp_lbl.set_text("N/A")
        return True

    # ── Sliders ───────────────────────────────────────────────────────────────
    def _build_sliders(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)

        # Volume
        if HAS["wpctl"]:
            vol_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            vh = Gtk.Box(spacing=8)
            vh.pack_start(Gtk.Label(label="󰕾"), False, False, 0)
            self.vol_lbl = Gtk.Label(label="Volume"); self.vol_lbl.set_name("slider-lbl")
            self.vol_pct = Gtk.Label(label="--");     self.vol_pct.set_name("slider-pct")
            vh.pack_start(self.vol_lbl, False, False, 0)
            vh.pack_end(self.vol_pct, False, False, 0)
            self.vol_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
            self.vol_scale.set_draw_value(False)
            self.vol_scale.set_hexpand(True)
            try:
                out = run("wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@")
                cur = int(float(out.split(":")[1].strip().split()[0]) * 100)
            except: cur = 50
            self.vol_scale.set_value(cur); self.vol_pct.set_text(f"{cur}%")
            self.vol_scale.connect("value-changed", self._on_vol)
            vol_box.pack_start(vh, False, False, 0)
            vol_box.pack_start(self.vol_scale, False, False, 0)
            box.pack_start(vol_box, False, False, 0)
        else:
            box.pack_start(self._unavailable("󰕾", "Volume — wpctl not found"), False, False, 0)

        # Brightness
        if HAS["brightnessctl"]:
            bri_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            bh = Gtk.Box(spacing=8)
            bh.pack_start(Gtk.Label(label="󰃠"), False, False, 0)
            self.bri_lbl = Gtk.Label(label="Brightness"); self.bri_lbl.set_name("slider-lbl")
            self.bri_pct = Gtk.Label(label="--");         self.bri_pct.set_name("slider-pct")
            bh.pack_start(self.bri_lbl, False, False, 0)
            bh.pack_end(self.bri_pct, False, False, 0)
            self.bri_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 1, 100, 1)
            self.bri_scale.set_draw_value(False)
            self.bri_scale.set_hexpand(True)
            try:
                cur_b = int(run("brightnessctl", "g") or 0)
                max_b = int(run("brightnessctl", "m") or 1)
                cur_b = int((cur_b / max_b) * 100)
            except: cur_b = 50
            self.bri_scale.set_value(cur_b); self.bri_pct.set_text(f"{cur_b}%")
            self.bri_scale.connect("value-changed", self._on_bri)
            bri_box.pack_start(bh, False, False, 0)
            bri_box.pack_start(self.bri_scale, False, False, 0)
            box.pack_start(bri_box, False, False, 0)
        else:
            box.pack_start(self._unavailable("󰃠", "Brightness — brightnessctl not found"), False, False, 0)

        return box

    def _on_vol(self, w):
        if not HAS["wpctl"]: return
        v = int(w.get_value()); self.vol_pct.set_text(f"{v}%")
        subprocess.run(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{v/100:.2f}"],
                       stderr=subprocess.DEVNULL)
        self._queue_osd("volume", v)

    def _on_bri(self, w):
        if not HAS["brightnessctl"]: return
        v = int(w.get_value()); self.bri_pct.set_text(f"{v}%")
        subprocess.run(["brightnessctl", "set", f"{v}%"], stderr=subprocess.DEVNULL)
        self._queue_osd("bright", v)

    # ── Toggles (WiFi + Bluetooth) ────────────────────────────────────────────
