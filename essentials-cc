    def _get_notifications(self):
        """Try makoctl then dunstctl for notification history."""
        if not HAS["makoctl"] and not HAS["dunstctl"]:
            return []
        # mako
        raw = run("makoctl", "history", fallback="") if HAS["makoctl"] else ""
        if raw:
            try:
                items = json.loads(raw)
                notifs = []
                for group in (items if isinstance(items, list) else [items]):
                    for n in (group if isinstance(group, list) else [group]):
                        app   = n.get("app-name", {}).get("data", "App")
                        body  = n.get("body",     {}).get("data", "")
                        notifs.append((str(app), str(body)))
                return notifs[-8:][::-1]
            except: pass

        # dunst
        raw = run("dunstctl", "history", fallback="") if HAS["dunstctl"] else ""
        if raw:
            try:
                data   = json.loads(raw)
                items  = data.get("data", [[]])[0]
                notifs = []
                for n in items:
                    app  = n.get("appname",  {}).get("data", "App")
                    body = n.get("body",     {}).get("data", "")
                    notifs.append((str(app), str(body)))
                return notifs[:8]
            except: pass

        return []

    def _on_dnd_toggle(self, sw, _p):
        HAS["do_not_disturb"] = sw.get_active()
        if sw.get_active():
            if HAS["makoctl"]:  run_ok("makoctl","set-mode","do-not-disturb")
            if HAS["dunstctl"]: run_ok("dunstctl","set-paused","true")
            # Pause idle daemon while DND is on
            run_ok("pkill","-STOP","-f","essentials-idle")
            self._spawn_osd("notif", "dnd-on")
        else:
            if HAS["makoctl"]:  run_ok("makoctl","set-mode","default")
            if HAS["dunstctl"]: run_ok("dunstctl","set-paused","false")
            # Resume idle daemon
            run_ok("pkill","-CONT","-f","essentials-idle")
            self._spawn_osd("notif", "dnd-off")

    def _load_notifications(self):
        for c in self.notif_box.get_children():
            self.notif_box.remove(c)

        notifs = self._get_notifications()
        if not notifs:
            if not HAS["makoctl"] and not HAS["dunstctl"]:
                msg = "No notification daemon  (install mako or dunst)"
            else:
                msg = "No recent notifications"
            empty = Gtk.Label(label=msg)
            empty.set_name("notif-empty"); empty.set_halign(Gtk.Align.START)
            self.notif_box.pack_start(empty, False, False, 0)
        else:
            for app, body in notifs:
                row = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                row.set_name("notif-row")
                app_lbl  = Gtk.Label(label=app);            app_lbl.set_name("notif-app")
                app_lbl.set_halign(Gtk.Align.START)
                body_lbl = Gtk.Label(label=body[:80] + ("…" if len(body) > 80 else ""))
                body_lbl.set_name("notif-body")
                body_lbl.set_halign(Gtk.Align.START)
                body_lbl.set_line_wrap(True)
                row.pack_start(app_lbl,  False, False, 0)
                row.pack_start(body_lbl, False, False, 0)
                self.notif_box.pack_start(row, False, False, 0)

        self.notif_box.show_all()

    def _clear_notifications(self, *_):
        if HAS["makoctl"]:   run_ok("makoctl", "dismiss", "--all")
        if HAS["dunstctl"]:  run_ok("dunstctl", "close-all")
        self._load_notifications()
        self._spawn_osd("notif", "cleared")

    def _load_clipboard(self):
        for c in self._clip_box.get_children(): self._clip_box.remove(c)
        if not HAS["cliphist"]:
            lbl = Gtk.Label(label="cliphist not installed")
            lbl.set_name("notif-empty"); lbl.set_halign(Gtk.Align.START)
            self._clip_box.pack_start(lbl, False, False, 0)
            self._clip_box.show_all()
            return
        entries = run("cliphist", "list").splitlines()[:12]
        if not entries:
            lbl = Gtk.Label(label="Clipboard is empty")
            lbl.set_name("notif-empty"); lbl.set_halign(Gtk.Align.START)
            self._clip_box.pack_start(lbl, False, False, 0)
        for entry in entries:
            # cliphist format: "ID	content"
            parts  = entry.split("	", 1)
            cid    = parts[0].strip() if len(parts) > 1 else ""
            text   = parts[1] if len(parts) > 1 else entry
            row    = Gtk.Box(spacing=8); row.set_name("notif-row")
            lbl    = Gtk.Label(label=text[:60] + ("…" if len(text) > 60 else ""))
            lbl.set_name("notif-body"); lbl.set_halign(Gtk.Align.START)
            lbl.set_hexpand(True); lbl.set_ellipsize(3)
            copy_btn = Gtk.Button(label="󰆏"); copy_btn.set_name("notif-clear-btn")
            copy_btn.connect("clicked", lambda _, e=entry: self._paste_clip(e))
            row.pack_start(lbl,      True,  True,  0)
            row.pack_start(copy_btn, False, False, 0)
            self._clip_box.pack_start(row, False, False, 0)
        self._clip_box.show_all()

    def _paste_clip(self, entry):
        """Decode and paste a cliphist entry."""
        try:
            proc = subprocess.Popen(["cliphist", "decode"],
                                    stdin=subprocess.PIPE, stdout=subprocess.PIPE,
                                    stderr=subprocess.DEVNULL)
            out, _ = proc.communicate(entry.encode())
            if HAS["wl-copy"]:
                subprocess.run(["wl-copy"], input=out, stderr=subprocess.DEVNULL)
        except Exception as e:
            print(f"[cc] clip paste: {e}")

    def _clear_clipboard(self, *_):
        if HAS["cliphist"]: run_ok("cliphist", "wipe")
        self._load_clipboard()

