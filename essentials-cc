        # WiFi
        self.wifi_state = self._wifi_enabled()
        wifi_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        wifi_card.set_name("toggle-card")
        wh = Gtk.Box(spacing=8)
        wifi_icon = Gtk.Label(label="󰖩"); wifi_icon.set_name("toggle-icon")
