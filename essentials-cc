# ── Helpers ───────────────────────────────────────────────────────────────────
import shutil

def has(cmd):
    """Return True if `cmd` is on PATH."""
    return shutil.which(cmd) is not None

def run(*cmd, fallback=""):
    try:    return subprocess.check_output(list(cmd), text=True, stderr=subprocess.DEVNULL).strip()
    except: return fallback

def run_ok(*cmd):
    try:    subprocess.run(list(cmd), check=True, stderr=subprocess.DEVNULL); return True
    except: return False

# ── Capability detection (done once at startup) ────────────────────────────
HAS = {
    "wpctl":        has("wpctl"),
    "brightnessctl": has("brightnessctl"),
    "playerctl":    has("playerctl"),
    "nmcli":        has("nmcli"),
    "bluetoothctl": has("bluetoothctl"),
    "makoctl":      has("makoctl"),
    "dunstctl":     has("dunstctl"),
    "do_not_disturb": False,  # runtime state, not a tool
    "psutil":       True,  # imported at top; will fail loudly if missing
    "cliphist":     has("cliphist"),
    "wl-paste":     has("wl-paste"),
    "wl-copy":      has("wl-copy"),
}
# Check psutil sensors (not all builds support it)
try:
    psutil.sensors_temperatures()
    HAS["sensors"] = True
except Exception:
    HAS["sensors"] = False


