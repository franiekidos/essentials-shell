        inner.pack_start(self._sep(),                 False, False, 0)
        inner.pack_start(self._build_stats(),         False, False, 0)
        inner.pack_start(self._sep(),                 False, False, 0)
        inner.pack_start(self._build_sliders(),       False, False, 0)
        inner.pack_start(self._sep(),                 False, False, 0)
        inner.pack_start(self._build_toggles(),       False, False, 0)
        inner.pack_start(self._sep(),                 False, False, 0)
        inner.pack_start(self._build_media(),         False, False, 0)
        inner.pack_start(self._sep(),                 False, False, 0)
        inner.pack_start(self._build_notifications(), False, False, 0)
        inner.pack_start(self._sep(),                 False, False, 0)
        inner.pack_start(self._build_actions(),       False, False, 0)

        self.apply_style()
