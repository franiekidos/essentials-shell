    # ── Stylesheet ────────────────────────────────────────────────────────────
    def _on_click_outside(self, win, event):
        """Dismiss CC if the click lands outside the inner content box."""
        child = win.get_child()
        if child is None:
            Gtk.main_quit()
            return False
        alloc = child.get_allocation()
        x, y = int(event.x), int(event.y)
        if not (alloc.x <= x <= alloc.x + alloc.width and
                alloc.y <= y <= alloc.y + alloc.height):
            Gtk.main_quit()
        return False

