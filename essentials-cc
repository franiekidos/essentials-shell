        else:
            box.pack_start(self._unavailable("󰖩", "Wi-Fi  (nmcli not found)"), True, True, 0)

        # Bluetooth
        self.bt_state = self._bt_enabled()
        bt_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        bt_card.set_name("toggle-card")
        bh = Gtk.Box(spacing=8)
        bt_icon = Gtk.Label(label="󰂯"); bt_icon.set_name("toggle-icon")
        bh.pack_start(bt_icon, False, False, 0)
        bh.pack_start(Gtk.Label(label="Bluetooth"), False, False, 0)
        self.bt_sw = Gtk.Switch(); self.bt_sw.set_active(self.bt_state)
        self.bt_sw.set_halign(Gtk.Align.END)
        bh.pack_end(self.bt_sw, False, False, 0)
        self.bt_dev = Gtk.Label(label=self._bt_device())
        self.bt_dev.set_name("toggle-sub")
        self.bt_dev.set_halign(Gtk.Align.START)
        self.bt_dev.set_ellipsize(3)
        bt_card.pack_start(bh,          False, False, 0)
        bt_card.pack_start(self.bt_dev, False, False, 0)
        if HAS["bluetoothctl"]:
            self.bt_sw.connect("notify::active", self._on_bt_toggle)
            box.pack_start(bt_card, True, True, 0)
        else:
            box.pack_start(self._unavailable("󰂯", "Bluetooth  (bluetoothctl not found)"), True, True, 0)

        # Dock toggle row
        dock_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        dock_card.set_name("toggle-card")
        dh = Gtk.Box(spacing=8)
        dk_icon = Gtk.Label(label="󰣉"); dk_icon.set_name("toggle-icon")
        dh.pack_start(dk_icon, False, False, 0)
        dh.pack_start(Gtk.Label(label="Dock"), False, False, 0)
        self._dock_sw = Gtk.Switch()
        self._dock_sw.set_active(self._dock_running())
        self._dock_sw.set_halign(Gtk.Align.END)
        dh.pack_end(self._dock_sw, False, False, 0)
        dock_card.pack_start(dh, False, False, 0)
        self._dock_sw.connect("notify::active", self._on_dock_toggle)
        box.pack_start(dock_card, True, True, 0)

        return box

    def _dock_running(self):
        import subprocess as _sp
        try:
            _sp.check_output(["pgrep","-f","essentials-dock"], stderr=_sp.DEVNULL)
            return True
        except: return False

    def _on_dock_toggle(self, sw, _p):
        _osd = os.path.expanduser("~/.local/bin/essentials-dock")
        if sw.get_active():
            subprocess.Popen(["python3", _osd], stderr=subprocess.DEVNULL)
        else:
            subprocess.run(["pkill","-f","essentials-dock"], stderr=subprocess.DEVNULL)

    def _build_weather_strip(self):
        """Single-line weather summary at the top of the CC."""
        box = Gtk.Box(spacing=12); box.set_name("weather-strip")
        self._wx_icon  = Gtk.Label(label="󰖐"); self._wx_icon.set_name("wx-icon")
        self._wx_temp  = Gtk.Label(label="--"); self._wx_temp.set_name("wx-temp")
        self._wx_desc  = Gtk.Label(label=""); self._wx_desc.set_name("wx-desc")
        self._wx_loc   = Gtk.Label(label=""); self._wx_loc.set_name("wx-loc")
        self._wx_loc.set_halign(Gtk.Align.END); self._wx_loc.set_hexpand(True)
        box.pack_start(self._wx_icon, False, False, 0)
        box.pack_start(self._wx_temp, False, False, 0)
        box.pack_start(self._wx_desc, False, False, 0)
        box.pack_end(self._wx_loc,    False, False, 0)
        self._fetch_weather_strip()
        return box

    def _fetch_weather_strip(self):
        import threading as _th, importlib.util, importlib.machinery
        def _do():
            path = os.path.expanduser("~/.local/bin/essentials-weather")
            try:
                loader = importlib.machinery.SourceFileLoader("ew", path)
                spec   = importlib.util.spec_from_loader("ew", loader)
                mod    = importlib.util.module_from_spec(spec)
                loader.exec_module(mod)
                d   = mod.fetch_weather()
                sym = d.get("unit_symbol","°C")
                from gi.repository import GLib
                GLib.idle_add(lambda: (
                    self._wx_icon.set_text(d.get("icon","󰖐")),
                    self._wx_temp.set_text(f"{d['temp']}{sym}"),
                    self._wx_desc.set_text(d.get("description","")),
                    self._wx_loc.set_text(d.get("location_name","")[:16]),
                    False)[-1])
            except Exception as e:
                print(f"[cc] weather strip: {e}")
        _th.Thread(target=_do, daemon=True).start()

    def _wifi_enabled(self):
        if not HAS["nmcli"]: return False
        return run("nmcli", "radio", "wifi", fallback="disabled").strip() == "enabled"

    def _wifi_ssid(self):
        if not HAS["nmcli"]: return "nmcli not found"
        try:
            lines = run("nmcli", "-t", "-f", "active,ssid", "dev", "wifi").splitlines()
            ssids = [l.split(":")[1] for l in lines if l.startswith("yes:")]
            return ssids[0] if ssids else "Not connected"
        except: return "Not connected"

    def _bt_enabled(self):
        if not HAS["bluetoothctl"]: return False
        out = run("bluetoothctl", "show", fallback="")
        return "Powered: yes" in out

    def _bt_device(self):
        if not HAS["bluetoothctl"]: return "bluetoothctl not found"
        out = run("bluetoothctl", "info", fallback="")
        for line in out.splitlines():
            if "Name:" in line: return line.split("Name:")[1].strip()
        return "No device"

    def _on_wifi_toggle(self, sw, _param):
        if not HAS["nmcli"]: return
        state = "on" if sw.get_active() else "off"
        subprocess.run(["nmcli", "radio", "wifi", state], stderr=subprocess.DEVNULL)
        GLib.timeout_add(1200, lambda: (
            self.wifi_ssid.set_text(self._wifi_ssid()), False
        ))

    def _on_bt_toggle(self, sw, _param):
        if not HAS["bluetoothctl"]: return
        state = "on" if sw.get_active() else "off"
        subprocess.run(["bluetoothctl", "power", state], stderr=subprocess.DEVNULL)
        GLib.timeout_add(800, lambda: (
            self.bt_dev.set_text(self._bt_device()), False
        ))

    # ── Media card ────────────────────────────────────────────────────────────
    def _build_media(self):
        if not HAS["playerctl"]:
            row = self._unavailable("󰝚", "Media — playerctl not found")
            row.set_name("media-card"); return row
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.set_name("media-card")

        # Title + artist
        info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        self.m_title  = Gtk.Label(label="Nothing playing")
        self.m_title.set_name("media-title")
        self.m_title.set_halign(Gtk.Align.START)
        self.m_title.set_ellipsize(3)
        self.m_artist = Gtk.Label(label="—")
        self.m_artist.set_name("media-artist")
        self.m_artist.set_halign(Gtk.Align.START)
        self.m_artist.set_ellipsize(3)
        info.pack_start(self.m_title,  False, False, 0)
        info.pack_start(self.m_artist, False, False, 0)
        card.pack_start(info, False, False, 0)

        # Progress bar
        self.m_progress = Gtk.ProgressBar()
        self.m_progress.set_name("media-progress")
        self.m_progress.set_fraction(0)
        card.pack_start(self.m_progress, False, False, 0)

        # Controls
        ctrl = Gtk.Box(spacing=0, homogeneous=True)
        ctrl.set_name("media-controls")
        for icon, cmd in [("󰒮", "previous"), ("󰐊", "play-pause"), ("󰒭", "next")]:
            b = Gtk.Button(label=icon); b.set_name("media-btn")
            b.connect("clicked", lambda w, c=cmd: subprocess.run(
                ["playerctl", c], stderr=subprocess.DEVNULL))
            ctrl.pack_start(b, True, True, 0)
        card.pack_start(ctrl, False, False, 0)
        return card

    def _update_media(self):
        if not HAS["playerctl"]: return False
        title  = run("playerctl", "metadata", "title",  fallback="")
        artist = run("playerctl", "metadata", "artist", fallback="")
        status = run("playerctl", "status",              fallback="Stopped")

        if title:
            self.m_title.set_text(title)
            self.m_artist.set_text(artist or "Unknown artist")
            play_icon = "󰏤" if status == "Playing" else "󰐊"
            # update play/pause button icon
            ctrl = self.m_progress.get_parent().get_children()[2]
            ctrl.get_children()[1].set_label(play_icon)
            # progress
            try:
                pos = float(run("playerctl", "position", fallback="0") or 0)
                length_us = float(run("playerctl", "metadata", "mpris:length", fallback="0") or 0)
                if length_us > 0:
                    self.m_progress.set_fraction(min(pos / (length_us / 1e6), 1.0))
            except: pass
        else:
            self.m_title.set_text("Nothing playing")
            self.m_artist.set_text("—")
            self.m_progress.set_fraction(0)
        return True

