    def _read_input_config(self):
        """Parse the compositor config and return current input settings as a flat dict."""
        conf = WM.get_config_path()
        if not conf or not os.path.exists(conf):
            return {}
        try:
            with open(conf) as f: lines = f.readlines()
        except: return {}

        result = {}
        if WM.name == "hyprland":
            # Find input { } block and parse key = value lines inside it
            in_block, depth = False, 0
            for line in lines:
                s = line.strip()
                if re.match(r"^input\s*{", s):
                    in_block, depth = True, 1; continue
                if in_block:
                    depth += s.count("{") - s.count("}")
                    if depth <= 0: break
                    if "=" in s and not s.startswith("#"):
                        k, _, v = s.partition("=")
                        result[k.strip()] = v.strip()

        elif WM.name == "sway":
            # input * { ... } or input "type:pointer" { ... }
            in_block, depth = False, 0
            for line in lines:
                s = line.strip()
                if re.match(r"^input\s+", s) and "{" in s:
                    in_block, depth = True, s.count("{") - s.count("}"); continue
                if in_block:
                    depth += s.count("{") - s.count("}")
                    if depth <= 0: break
                    # sway: "natural_scroll enabled"
                    parts = s.split()
                    if len(parts) >= 2 and not s.startswith("#"):
                        result[parts[0]] = parts[1]

        elif WM.name in ("river", "mangowc"):
            # riverctl input DEVICE prop VALUE
            for line in lines:
                s = line.strip()
                m = re.match(r"riverctl input \S+ (\S+)\s+(\S+)", s)
                if m: result[m.group(1).replace("-","_")] = m.group(2)

        return result

    def _apply_input(self, _b):
        props = {
            "sensitivity":    self._speed_scale.get_value(),
            "natural_scroll": self._nat_scroll_sw.get_active(),
            "tap_button_map": "lmr" if self._tap_sw.get_active() else "none",
            "left_handed":    self._lefthanded_sw.get_active(),
            "accel_profile":  "adaptive" if self._accel_sw.get_active() else "flat",
            "scroll_factor":  self._scroll_scale.get_value(),
        }

        errors = []
        written = False

        # ── 1. Write to config file ───────────────────────────────────────────
        conf = WM.get_config_path()
        if CW and conf and os.path.exists(conf):
            writer = CW.get_writer(WM.name, conf)
            if writer:
                try:
                    if WM.name == "hyprland":
                        # Map to hyprland input block keys
                        hl = {
                            "sensitivity":    f"{props['sensitivity']:.3f}",
                            "natural_scroll": "true" if props["natural_scroll"] else "false",
                            "left_handed":    "true" if props["left_handed"] else "false",
                            "accel_profile":  props["accel_profile"],
                            "scroll_factor":  f"{props['scroll_factor']:.2f}",
                        }
                        if self._tap_sw.get_active():
                            hl["tap_button_map"] = "lmr"
                        for k, v in hl.items():
                            writer._set_nested("input", k, v)
                        written = True

                    elif WM.name in ("sway", "river"):
                        sway_props = {
                            "pointer_speed":  props["sensitivity"],
                            "natural_scroll": props["natural_scroll"],
                            "tap":            self._tap_sw.get_active(),
                            "left_handed":    props["left_handed"],
                        }
                        writer.set_input("type:pointer", sway_props)
                        written = True

                except Exception as e:
                    errors.append(f"Config write: {e}")

        # ── 2. Apply live via IPC ─────────────────────────────────────────────
        live_ok = False
        try:
            if WM.name == "hyprland":
                ipc_map = {
                    "sensitivity":   f"{props['sensitivity']:.3f}",
                    "natural_scroll": "true" if props["natural_scroll"] else "false",
                    "left_handed":    "true" if props["left_handed"] else "false",
                    "accel_profile":  props["accel_profile"],
                    "scroll_factor":  f"{props['scroll_factor']:.2f}",
                }
                if self._tap_sw.get_active():
                    ipc_map["tap_button_map"] = "lmr"
                for k, v in ipc_map.items():
                    r = subprocess.run(
                        ["hyprctl", "keyword", f"input:{k}", v],
                        stderr=subprocess.DEVNULL)
                    if r.returncode != 0:
                        errors.append(f"hyprctl keyword input:{k} failed")
                live_ok = not errors

            elif WM.name == "sway":
                sway_cmds = [
                    f"input type:pointer accel_speed {props['sensitivity']:.3f}",
                    f"input type:pointer natural_scroll {'enabled' if props['natural_scroll'] else 'disabled'}",
                    f"input type:pointer left_handed {'enabled' if props['left_handed'] else 'disabled'}",
                    f"input type:pointer tap {'enabled' if self._tap_sw.get_active() else 'disabled'}",
                ]
                for cmd in sway_cmds:
                    r = subprocess.run(["swaymsg", cmd], stderr=subprocess.DEVNULL)
                    if r.returncode != 0:
                        errors.append(f"swaymsg failed: {cmd}")
                live_ok = not errors
        except Exception as e:
            errors.append(f"IPC: {e}")

        # ── Show result ───────────────────────────────────────────────────────
        p = self._palette()
        clr_ok   = p.get("green",  "#a6e3a1")
        clr_warn = p.get("yellow", "#f9e2af")
        clr_err  = p.get("red",    "#f38ba8")
        if errors:
            self._input_status.set_markup(
                f"<span foreground='{clr_err}'>⚠  {'; '.join(errors)}</span>")
        elif written and live_ok:
            self._input_status.set_markup(
                f"<span foreground='{clr_ok}'>✓  Saved to config and applied live.</span>")
        elif written:
            self._input_status.set_markup(
                f"<span foreground='{clr_warn}'>✓  Saved to config. "
                "Reload compositor to apply.</span>")
        elif live_ok:
            self._input_status.set_markup(
                f"<span foreground='{clr_warn}'>✓  Applied live only "
                "(config not found — changes lost on restart).</span>")
        else:
            self._input_status.set_markup(
                f"<span foreground='{clr_err}'>⚠  No config found and IPC unavailable "
                f"for {WM.name}.</span>")

