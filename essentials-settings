    def _palette(self):
        """
        Build the full colour palette from the active theme in themes.json.
        The theme supplies bg, accent, text (and optionally more).
        Everything else is derived algorithmically so ANY theme works.
        """
        import colorsys, re as _re

        # ── Load active theme ─────────────────────────────────────────────────
        try:
            data  = json.load(open(THEME_PATH))
            tname = data.get("current", "catppuccin")
            t     = data.get(tname, data.get("catppuccin", {}))
        except Exception:
            t = {}

        raw_bg     = t.get("bg",     "rgba(17,17,27,0.92)")
        raw_accent = t.get("accent", "#cba6f7").lstrip("#")
        raw_text   = t.get("text",   "#cdd6f4").lstrip("#")

        # ── Parse accent hex → RGB ────────────────────────────────────────────
        def _parse_hex(h):
            h = h.lstrip("#")
            return tuple(int(h[i:i+2], 16) / 255 for i in (0, 2, 4))

        def _hex(r, g, b):
            return "{:02x}{:02x}{:02x}".format(
                int(r*255), int(g*255), int(b*255))

        def _shift(h6, sat_mul=1.0, val_mul=1.0):
            r, g, b = _parse_hex(h6)
            hh, s, v = colorsys.rgb_to_hsv(r, g, b)
            s2 = max(0, min(1, s * sat_mul))
            v2 = max(0, min(1, v * val_mul))
            return _hex(*colorsys.hsv_to_rgb(hh, s2, v2))

        def _rgba_dim(h6, a=0.12):
            r, g, b = _parse_hex(h6)
            return f"rgba({int(r*255)},{int(g*255)},{int(b*255)},{a})"

        # ── Extract bg RGB ────────────────────────────────────────────────────
        m = _re.match(r"rgba[(]([0-9]+),[ ]*([0-9]+),[ ]*([0-9]+)", raw_bg)
        if m:
            br, bg_, bb = int(m.group(1)), int(m.group(2)), int(m.group(3))
        else:
            mm = _re.match(r"[#]?([0-9a-fA-F]{6})", raw_bg)
            if mm:
                br = int(mm.group(1)[0:2],16)
                bg_ = int(mm.group(1)[2:4],16)
                bb = int(mm.group(1)[4:6],16)
            else:
                br, bg_, bb = 17, 17, 27

        # Is the bg dark or light?
        luma      = (0.299*br + 0.587*bg_ + 0.114*bb) / 255
        is_dark   = luma < 0.5 or not self.dark_mode is False

        # ── Derive surface colours from bg ────────────────────────────────────
        def _step(factor):
            if is_dark:
                r2 = min(255, int(br + factor))
                g2 = min(255, int(bg_ + factor))
                b2 = min(255, int(bb + factor))
            else:
                r2 = max(0, int(br - factor))
                g2 = max(0, int(bg_ - factor))
                b2 = max(0, int(bb - factor))
            return "{:02x}{:02x}{:02x}".format(r2, g2, b2)

        win_bg     = "{:02x}{:02x}{:02x}".format(br, bg_, bb)
        header_bg  = _step(8)
        page_bg    = win_bg
        surface    = _step(17)
        surface2   = _step(30)
        surface3   = _step(45)
        header_sep = surface
        win_border = surface2

        # ── Text colours ──────────────────────────────────────────────────────
        text    = raw_text
        # subtext = text but 40% less saturated / dimmer
        subtext = _shift(raw_text, sat_mul=0.5, val_mul=0.65)

        # ── Accent-derived colours ────────────────────────────────────────────
        accent      = raw_accent
        tab_act_fg  = accent
        thumb       = surface2

        # Blue: shift accent hue by +30°
        ar, ag, ab  = _parse_hex(accent)
        ah, as_, av = colorsys.rgb_to_hsv(ar, ag, ab)
        blue        = _hex(*colorsys.hsv_to_rgb((ah + 0.083) % 1, as_, av))

        # Red: shift accent hue by -120°
        red         = _hex(*colorsys.hsv_to_rgb((ah - 0.333) % 1, as_, min(1, av*1.1)))

        # Yellow: shift accent hue to ~50°
        yellow      = _hex(*colorsys.hsv_to_rgb(0.138, max(0.5, as_), min(1, av*1.05)))

        # Green: shift accent hue to ~130°
        green_raw   = _hex(*colorsys.hsv_to_rgb(0.361, max(0.4, as_*0.8), min(1, av)))

        scroll_a    = "0.10" if is_dark else "0.18"

        return dict(
            win_bg=win_bg,       win_border=win_border,
            header_bg=header_bg, header_sep=header_sep,
            page_bg=page_bg,
            tab_fg=subtext,      tab_act_bg=surface,
            tab_act_fg=accent,   tab_border=surface2,
            text=text,           subtext=subtext,
            surface=surface,     surface2=surface2,    surface3=surface3,
            accent=accent,       accent_dim=_rgba_dim(accent),
            blue=blue,           blue_dim=_rgba_dim(blue),
            red=red,             red_dim=_rgba_dim(red),
            yellow=yellow,       yellow_dim=_rgba_dim(yellow),
            green=f"#{green_raw}",
            entry_bg=header_bg,  thumb=thumb,
            scroll=f"rgba(255,255,255,{scroll_a})",
        )

