    def _scan_wifi(self, _btn):
        self._wifi_status.set_text("Scanning…")
        for c in self._net_list.get_children(): self._net_list.remove(c)
        raw = _run("nmcli","-t","-f","IN-USE,SSID,SIGNAL,SECURITY","dev","wifi","list")
        seen = set()
        for line in raw.splitlines():
            parts = line.split(":")
            if len(parts) < 4: continue
            active, ssid, signal, sec = parts[0], parts[1], parts[2], parts[3]
            if not ssid or ssid in seen: continue
            seen.add(ssid)
            try: sig = int(signal)
            except: sig = 0
            sig_icon = "󰤨" if sig > 65 else "󰤥" if sig > 35 else "󰤢"
            lock = "󰌾 " if sec and sec != "--" else ""
            row = Gtk.Box(spacing=10); row.set_name("net-row")
            lbl = Gtk.Label(label=f"{sig_icon}  {ssid}  {lock}")
            lbl.set_halign(Gtk.Align.START); lbl.set_hexpand(True)
            lbl.set_name("net-active-lbl" if active == "*" else "net-lbl")
            btn = Gtk.Button(label="Disconnect" if active == "*" else "Connect")
            btn.set_name("small-btn-accent" if active == "*" else "small-btn")
            btn.connect("clicked", lambda w, s=ssid, a=(active=="*"): self._wifi_connect(s, a))
            row.pack_start(lbl, True,  True,  0)
            row.pack_start(btn, False, False, 0)
            self._net_list.pack_start(row, False, False, 0)
        self._net_list.show_all()
        active_raw = _run("nmcli","-t","-f","DEVICE,TYPE,STATE,CONNECTION","con","show","--active")
        self._active_net.set_text(active_raw[:140] if active_raw else "None")
        self._wifi_status.set_text(f"{len(seen)} networks found")
        return False

    def _wifi_connect(self, ssid, disconnect):
        if disconnect:
            subprocess.run(["nmcli","con","down",ssid], stderr=subprocess.DEVNULL)
        else:
            if subprocess.run(["nmcli","con","up",ssid],
                              stderr=subprocess.DEVNULL).returncode != 0:
                self._wifi_password_dialog(ssid)
        GLib.timeout_add(1500, lambda: (self._scan_wifi(None), False))

