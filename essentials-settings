        scroll = Gtk.ScrolledWindow()
        self._theme_list = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self._populate_themes()
        scroll.add(self._theme_list)
        page.pack_start(scroll, True, True, 0)

        self._theme_status_lbl = Gtk.Label(label="")
        self._theme_status_lbl.set_halign(Gtk.Align.START)
        self._theme_status_lbl.set_name("mono-lbl")
        page.pack_start(self._theme_status_lbl, False, False, 0)

        self._tab(page, "󰏘 Appearance")

    def _populate_themes(self):
        for c in self._theme_list.get_children(): self._theme_list.remove(c)
        if not os.path.exists(THEME_PATH): return
        with open(THEME_PATH) as f:
            data = json.load(f); current = data.get("current","")
        for name in [k for k in data if k != "current"]:
            row = Gtk.Box(spacing=16); row.set_name("theme-row")
            cb = Gtk.CheckButton(); cb.set_active(name == current)
            cb.connect("toggled", self._on_theme_toggle, name)
            self.theme_checks[name] = cb
            # Colour swatches
            theme = data[name]
            swatch_box = Gtk.Box(spacing=4)
            for key in ("bg","accent","text"):
                swatch = Gtk.Label(label="  ")
                swatch.set_name("swatch")
                ctx = swatch.get_style_context()
                css = Gtk.CssProvider()
                css.load_from_data(f"* {{ background-color: {theme.get(key,'#888')}; border-radius: 3px; }}".encode())
                ctx.add_provider(css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
                swatch_box.pack_start(swatch, False, False, 0)
            lbl = Gtk.Label(label=name.capitalize()); lbl.set_name("theme-text")
            row.pack_start(cb,          False, False, 10)
            row.pack_start(lbl,         False, False,  0)
            row.pack_end(swatch_box,    False, False, 10)
            self._theme_list.pack_start(row, False, False, 0)
        self._theme_list.show_all()

    def _on_theme_toggle(self, cb, name):
        if not cb.get_active(): return
        for t, o in self.theme_checks.items():
            if t != name: o.set_active(False)
        with open(THEME_PATH) as f: data = json.load(f)
        data["current"] = name
        theme = data.get(name, {})
        with open(THEME_PATH,"w") as f: json.dump(data,f,indent=4)
        # Apply WM borders immediately in-process
        wm_msg = ""
        if CW:
            conf = WM.get_config_path()
            ok, msg = CW.apply_wm_theme(WM.name, conf, theme)
            wm_msg = f"{'✓' if ok else '✗'} WM borders: {msg}"
            print(f"[settings] {wm_msg}")

        # Show brief result in a status label if present, else print
        if hasattr(self, "_theme_status_lbl"):
            p2 = self._palette()
            col = p2.get("green","#a6e3a1") if (not wm_msg or wm_msg.startswith("✓")) else p2.get("red","#f38ba8")
            self._theme_status_lbl.set_markup(f"<span foreground='{col}'>{wm_msg}</span>")

        # Restart bar + widgets with new theme
        subprocess.Popen(["python3", os.path.expanduser("~/.local/bin/essentials-theme-apply")])
        # Re-render settings UI with new palette
        self.apply_style()

    def _on_dark_toggle(self, sw, _p):
        self.dark_mode = sw.get_active()
        self._dm_icon.set_text("󰖔 " if self.dark_mode else "󰖙 ")
        self._dm_sub.set_text("Dark" if self.dark_mode else "Light")
        self._save_dark_mode(self.dark_mode)
        self.apply_style()

