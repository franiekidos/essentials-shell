#!/usr/bin/env python3
import gi, os, json, re, subprocess, shutil, importlib.util, importlib.machinery
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, GtkLayerShell, Gdk, GLib, Pango

# ── Load config-writer ───────────────────────────────────────────────────────
def _load_cw():
    path = os.path.expanduser("~/.local/bin/essentials-config-writer")
    if os.path.exists(path):
        try:
            loader = importlib.machinery.SourceFileLoader("essentials_config_writer", path)
            spec   = importlib.util.spec_from_loader("essentials_config_writer", loader)
            mod    = importlib.util.module_from_spec(spec)
            loader.exec_module(mod)
            return mod
        except Exception as e:
            print(f"[settings] config-writer load failed: {e}")
    return None

CW = _load_cw()   # the config-writer module, or None

THEME_PATH  = os.path.expanduser("~/.config/essentials/themes.json")
CONFIG_PATH = os.path.expanduser("~/.config/essentials/config.json")

# ── Load compositor abstraction ───────────────────────────────────────────────
def _load_wm():
    path = os.path.expanduser("~/.local/bin/essentials-detect")
    if os.path.exists(path):
        try:
            loader = importlib.machinery.SourceFileLoader("essentials_detect", path)
            spec   = importlib.util.spec_from_loader("essentials_detect", loader)
            mod    = importlib.util.module_from_spec(spec)
            loader.exec_module(mod)
            return mod.detect()
        except Exception as e:
            import warnings; warnings.warn(f"essentials-detect failed: {e}")
    class _FB:
        name="generic"
        def get_config_path(self): return None
        def get_monitors(self):    return []
        def set_monitor(self,*a):  return False
        def get_input_devices(self): return []
        def set_input(self,*a):    return False
        def parse_keybinds(self,l): return []
        def format_keybind(self,m,k,c): return f"# {m}+{k} {c}"
        def reload_config(self):   return False
        def supports_plugins(self): return False
        def get_plugins(self):     return []
        def plugin_action(self,*a): return False
        def add_plugin_repo(self,u): return False
    return _FB()

WM = _load_wm()

def _has(cmd): return shutil.which(cmd) is not None
def _run(*cmd, fallback=""):
    try:    return subprocess.check_output(list(cmd),text=True,stderr=subprocess.DEVNULL).strip()
    except: return fallback


class EssentialsSettings(Gtk.Window):
    def __init__(self):
        Gtk.Window.__init__(self)
        GtkLayerShell.init_for_window(self)
        GtkLayerShell.set_layer(self, GtkLayerShell.Layer.OVERLAY)
        GtkLayerShell.set_keyboard_mode(self, GtkLayerShell.KeyboardMode.ON_DEMAND)
        self.connect("key-press-event", self.on_key_press)
        self.theme_checks = {}
        self.dark_mode = self._load_dark_mode()

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(root)

        # Header
        hdr = Gtk.Box(spacing=10)
        hdr.set_margin_start(20); hdr.set_margin_end(20); hdr.set_margin_top(14)
        self._header_title = Gtk.Label()
        self._header_title.set_markup(
            f"<span size='large' weight='bold'>Essentials Settings  "
            f"<span size='small'>[{WM.name}]</span></span>")
        title = self._header_title
        close_btn = Gtk.Button(label="✕"); close_btn.set_size_request(32,32)
        close_btn.connect("clicked", lambda w: Gtk.main_quit())
        hdr.pack_start(title, False, False, 0)
        hdr.pack_end(close_btn, False, False, 0)
        root.pack_start(hdr, False, False, 14)

        self.notebook = Gtk.Notebook()
        root.pack_start(self.notebook, True, True, 0)

        self._build_display_tab()
        self._build_appearance_tab()
        self._build_system_tab()
        self._build_network_tab()
        self._build_input_tab()
        self._build_clock_tab()
        self._build_keybinds_tab()
        self._build_fonts_tab()
        self._build_defaults_tab()
        self._build_plugins_tab()
        self._build_layout_tab()
        self._build_wallpaper_tab()
        self._build_widgets_tab()
        self._build_dock_tab()
        self._build_idle_tab()
        self._build_weather_tab()

        self.apply_style()
        self.set_size_request(1200, 740)
        self.show_all()

    # ── Shared helpers ────────────────────────────────────────────────────────
    def _load_dark_mode(self):
        try:
            with open(CONFIG_PATH) as f: return json.load(f).get("dark_mode", True)
        except: return True

    def _save_dark_mode(self, val):
        data = {}
        try:
            with open(CONFIG_PATH) as f: data = json.load(f)
        except: pass
        data["dark_mode"] = val
        os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
        with open(CONFIG_PATH,"w") as f: json.dump(data,f,indent=4)

    def _get_sys_val(self, kind):
        try:
            if kind == "vol":
                out = _run("wpctl","get-volume","@DEFAULT_AUDIO_SINK@")
                return int(float(out.split(":")[1].strip().split()[0]) * 100)
            if kind == "bri":
                c = int(_run("brightnessctl","g") or 0)
                m = int(_run("brightnessctl","m") or 1)
                return int(c/m*100)
        except: return 50

    def _tab(self, widget, label, hm=28, vm=20):
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        widget.set_margin_start(hm); widget.set_margin_end(hm)
        widget.set_margin_top(vm);   widget.set_margin_bottom(vm)
        scroll.add(widget)
        self.notebook.append_page(scroll, Gtk.Label(label=label))

    def _section(self, text):
        l = Gtk.Label(); l.set_halign(Gtk.Align.START)
        l.set_markup(f"<span weight='bold' size='small'>{text.upper()}</span>")
        l.set_name("section-heading"); return l

    def _entry_row(self, box, label, default, spacing=5):
        row = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=spacing)
        lbl = Gtk.Label(label=label); lbl.set_halign(Gtk.Align.START)
        ent = Gtk.Entry(); ent.set_text(default)
        row.pack_start(lbl, False, False, 0)
        row.pack_start(ent, False, False, 0)
        box.pack_start(row, False, False, 0)
        return ent

    def _msg(self, text, mtype=Gtk.MessageType.INFO):
        dlg = Gtk.MessageDialog(parent=self, flags=Gtk.DialogFlags.MODAL,
            message_type=mtype, buttons=Gtk.ButtonsType.OK, text=text)
        dlg.run(); dlg.destroy()

    # ── Display tab ───────────────────────────────────────────────────────────
    def _build_display_tab(self):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)

        left = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        left.set_margin_start(24); left.set_margin_end(24); left.set_margin_top(24)

        self.mon_entry = self._entry_row(left, "Monitor ID:",      "eDP-1")
        self.res_entry = self._entry_row(left, "Resolution @ Hz:", "preferred")
        self.rot_entry = self._entry_row(left, "Rotation (0-7):",  "0")
        self.scale_entry = self._entry_row(left, "Scale:",         "1.0")

        btns = Gtk.Box(spacing=10)
        a_btn = Gtk.Button(label="Apply"); a_btn.connect("clicked", self._apply_display)
        r_btn = Gtk.Button(label="Reset"); r_btn.connect("clicked",
            lambda w: (self.res_entry.set_text("preferred"),
                       self.rot_entry.set_text("0"), self.scale_entry.set_text("1.0")))
        reload_btn = Gtk.Button(label="󰑓 Reload Config"); reload_btn.set_name("btn-blue")
        reload_btn.connect("clicked", lambda w: WM.reload_config())
        btns.pack_start(a_btn,      True, True, 0)
        btns.pack_start(r_btn,      True, True, 0)
        btns.pack_start(reload_btn, True, True, 0)
        left.pack_start(btns, False, False, 8)

        # Compositor capability badge
        cap_lbl = Gtk.Label(label=f"Compositor: {WM.name}  |  "
            f"wlr-randr: {'yes' if _has('wlr-randr') else 'no'}")
        cap_lbl.set_name("mono-lbl"); cap_lbl.set_halign(Gtk.Align.START)
        left.pack_start(cap_lbl, False, False, 0)

        right = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        right.set_size_request(360,-1); right.set_name("help-panel")
        right.set_margin_start(8); right.set_margin_end(8)
        right.set_margin_top(8);   right.set_margin_bottom(8)
        rscroll = Gtk.ScrolledWindow()
        self.modes_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        rscroll.add(self.modes_box)
        right.pack_start(rscroll, True, True, 0)
        box.pack_start(left,  True,  True,  0)
        box.pack_start(right, False, False, 0)
        self.notebook.append_page(box, Gtk.Label(label="󰍹 Display"))
        GLib.idle_add(self._populate_modes)

    def _populate_modes(self):
        for c in self.modes_box.get_children(): self.modes_box.remove(c)
        for m in WM.get_monitors():
            self.modes_box.pack_start(
                self._section(m.get("name","?")), False, False, 4)
            for mode in m.get("modes",[]):
                lbl = f"{mode['res']}@{mode['refresh']}Hz"
                b = Gtk.Button(label=lbl)
                b.connect("clicked", lambda w, mon=m["name"], r=lbl: (
                    self.mon_entry.set_text(mon),
                    self.res_entry.set_text(r)))
                self.modes_box.pack_start(b, False, False, 0)
        if not WM.get_monitors():
            self.modes_box.pack_start(
                Gtk.Label(label="(no monitors via IPC)"), False, False, 5)
        self.modes_box.show_all()
        return False

    def _apply_display(self, _b):
        name  = self.mon_entry.get_text().strip()
        res   = self.res_entry.get_text().strip()
        rot   = int(self.rot_entry.get_text() or 0)
        scale = float(self.scale_entry.get_text() or 1.0)

        # 1. Write to config file
        conf  = WM.get_config_path()
        wrote = False
        if CW and conf:
            writer = CW.get_writer(WM.name, conf)
            if writer and hasattr(writer, "set_monitor"):
                try:
                    writer.set_monitor(name, res, "auto", scale, rot)
                    wrote = True
                except Exception as e:
                    self._msg(f"Config write failed: {e}", Gtk.MessageType.ERROR)
                    return

        # 2. Apply live via IPC
        ok = WM.set_monitor(name, res, rot, scale)

        if wrote and ok:
            self._msg(f"Applied and saved to {conf}")
        elif wrote:
            self._msg(f"Saved to {conf}\n(live apply not supported for {WM.name} — reload compositor to apply)")
        elif ok:
            self._msg(f"Applied live.\nNote: not written to config — changes lost on restart.")
        else:
            self._msg(
                f"Could not apply or write monitor config for {WM.name}.",
                Gtk.MessageType.WARNING)

    # ── Appearance tab ────────────────────────────────────────────────────────
    def _build_appearance_tab(self):
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)

        # Dark mode row
        dm_row = Gtk.Box(spacing=15); dm_row.set_name("theme-row")
        self._dm_icon = Gtk.Label(label="󰖔 " if self.dark_mode else "󰖙 ")
        self._dm_icon.set_name("dm-icon")
        dm_lbl = Gtk.Label(); dm_lbl.set_markup("<b>Dark Mode</b>"); dm_lbl.set_name("theme-text")
        self._dm_sub = Gtk.Label(label="Dark" if self.dark_mode else "Light")
        self._dm_sub.set_name("dm-sub")
        self.dm_switch = Gtk.Switch(); self.dm_switch.set_active(self.dark_mode)
        self.dm_switch.connect("notify::active", self._on_dark_toggle)
        dl = Gtk.Box(spacing=10)
        dl.pack_start(self._dm_icon, False, False, 10)
        dl.pack_start(dm_lbl,        False, False, 0)
        dl.pack_start(self._dm_sub,  False, False, 4)
        dm_row.pack_start(dl,             True,  True,  0)
        dm_row.pack_start(self.dm_switch, False, False, 10)
        page.pack_start(dm_row, False, False, 0)
