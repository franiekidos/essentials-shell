    def _on_pin_remove(self, _):
        model, it = self._pin_view.get_selection().get_selected()
        if it:
            model.remove(it)

    def _pin_move(self, direction):
        model, it = self._pin_view.get_selection().get_selected()
        if not it: return
        path = model.get_path(it)
        idx  = path.get_indices()[0]
        swap = idx + direction
        if 0 <= swap < len(model):
            model.swap(model.get_iter(Gtk.TreePath(idx)),
                       model.get_iter(Gtk.TreePath(swap)))

