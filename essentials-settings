    def _load_timezones(self):
        self._tz_store.clear()
        self._all_tz = _run("timedatectl","list-timezones").splitlines()
        for tz in self._all_tz: self._tz_store.append([tz])
        # pre-select current
        cur = _run("timedatectl","show","--property=Timezone","--value",fallback="")
        for i, tz in enumerate(self._all_tz):
            if tz == cur:
                self._tz_view.set_cursor(Gtk.TreePath(i),None,False)
                break
        return False

    def _filter_tz(self, entry):
        q = entry.get_text().lower()
        self._tz_store.clear()
        for tz in getattr(self,"_all_tz",[]):
            if q in tz.lower(): self._tz_store.append([tz])

    def _on_tz_select(self, sel):
        model, it = sel.get_selected()
        if not it: return
        tz = model[it][0]
        ret = subprocess.run(["timedatectl","set-timezone",tz],
                             stderr=subprocess.DEVNULL)
        if ret.returncode == 0: self._update_clock()

