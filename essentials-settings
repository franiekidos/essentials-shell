    def _on_style_select(self, btn, style_id):
        # Guard against re-entrancy — set_active() on other buttons
        # would re-fire this signal and recurse infinitely.
        if getattr(self, "_style_lock", False):
            return
        if not btn.get_active():
            # User clicked the already-active button — keep it on
            self._style_lock = True
            btn.set_active(True)
            self._style_lock = False
            return
        self._style_lock = True
        for sid, b in self._style_btns.items():
            b.set_active(sid == style_id)
            b.set_name("style-btn-active" if sid == style_id else "style-btn")
        self._style_lock = False
        # Persist
        data = {}
        try:
            with open(CONFIG_PATH) as f: data = json.load(f)
        except: pass
        data["bar_style"] = style_id
        os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
        with open(CONFIG_PATH, "w") as f: json.dump(data, f, indent=4)

    def _on_autohide_toggle(self, sw, _p):
        try:
            with open(CONFIG_PATH) as f: data = json.load(f)
        except: data = {}
        data["bar_autohide"] = sw.get_active()
        with open(CONFIG_PATH,"w") as f: json.dump(data,f,indent=4)

    def _on_cc_compact_toggle(self, sw, _p):
        try:
            with open(CONFIG_PATH) as f:
                data = json.load(f)
        except Exception:
            data = {}
        data.setdefault("cc", {})["compact_buttons"] = sw.get_active()
        with open(CONFIG_PATH, "w") as f:
            json.dump(data, f, indent=4)

    def _add_widget_dialog(self, section, store, all_widgets):
        dlg = Gtk.Dialog(title="Add Widget", parent=self, flags=Gtk.DialogFlags.MODAL)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Add", Gtk.ResponseType.OK)
        c = dlg.get_content_area()
        c.set_margin_start(16); c.set_margin_end(16)
        c.set_margin_top(12);   c.set_margin_bottom(12)
        c.pack_start(Gtk.Label(label="Choose a widget:"), False, False, 4)
        combo = Gtk.ComboBoxText()
        for wid, lbl in all_widgets.items():
            combo.append(wid, lbl)
        combo.set_active(0)
        c.pack_start(combo, False, False, 4)
        dlg.show_all()
        if dlg.run() == Gtk.ResponseType.OK:
            wid = combo.get_active_id()
            if wid: store.append([wid, all_widgets[wid]])
        dlg.destroy()

    def _remove_widget(self, tv, store):
        sel = tv.get_selection()
        model, it = sel.get_selected()
        if it: store.remove(it)

    def _move_widget(self, tv, store, direction):
        sel = tv.get_selection()
        model, it = sel.get_selected()
        if not it: return
        path = model.get_path(it)
        idx  = path.get_indices()[0]
        target = idx + direction
        if target < 0 or target >= len(store): return
        store.swap(store.get_iter(Gtk.TreePath(idx)),
                   store.get_iter(Gtk.TreePath(target)))
        tv.get_selection().select_path(Gtk.TreePath(target))

    def _save_layout(self, _w=None):
        layout = {}
        for section, store in self._section_stores.items():
            layout[section] = [row[0] for row in store]
        if CW:
            CW.save_bar_layout(layout)
            self._msg("Bar layout saved. Click Restart Bar to apply.")
        else:
            self._msg("config-writer not found — could not save layout.",
                      Gtk.MessageType.ERROR)

    def _reset_layout(self, _w=None):
        defaults = {
            "left":   ["launcher","wm-badge","workspaces"],
            "center": ["media","clock"],
            "right":  ["network","cpu","ram","cc-button"],
        }
        for section, store in self._section_stores.items():
            store.clear()
            for wid in defaults.get(section, []):
                label = self._layout_all_widgets.get(wid, wid)
                store.append([wid, label])

