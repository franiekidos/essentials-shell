    def _load_fonts(self):
        self._font_store.clear()
        self._all_fonts = sorted(set(
            l.split(":")[0].strip()
            for l in _run("fc-list").splitlines() if ":" in l))
        for f in self._all_fonts: self._font_store.append([f])
        return False

    def _filter_fonts(self, e):
        q = e.get_text().lower()
        self._font_store.clear()
        for f in getattr(self,"_all_fonts",[]):
            if q in f.lower(): self._font_store.append([f])

    def _on_font_select(self, sel):
        model, it = sel.get_selected()
        if it: self._sel_font = model[it][0]; self._update_font_preview(None)

    def _update_font_preview(self, _w):
        font = getattr(self,"_sel_font","Sans")
        size = int(self._font_size.get_value())
        self._font_preview.override_font(Pango.FontDescription.from_string(f"{font} {size}"))

    def _save_font(self, _w):
        font = getattr(self,"_sel_font",None)
        if not font: return
        data = {}
        try:
            with open(CONFIG_PATH) as f: data = json.load(f)
        except: pass
        data["font"] = font
        with open(CONFIG_PATH,"w") as f: json.dump(data,f,indent=4)
        self._msg(f"Saved '{font}' as interface font.\nRestart the bar to apply.")

