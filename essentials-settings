    def _load_keybinds(self, path):
        self._kb_store.clear(); self._kb_conf = path
        try:
            with open(path) as f: lines = f.readlines()
        except: return
        self._kb_other = []
        for line in lines:
            parsed = WM.parse_keybinds([line])
            if parsed:
                self._kb_store.append(list(parsed[0]))
            else:
                self._kb_other.append(line)

    def _filter_kb(self, entry):
        q = entry.get_text().lower()
        # simple: reload and filter
        if not hasattr(self, "_kb_conf"): return
        try:
            with open(self._kb_conf) as f: lines = f.readlines()
        except: return
        self._kb_store.clear()
        for mod, key, cmd in WM.parse_keybinds(lines):
            if q in f"{mod} {key} {cmd}".lower():
                self._kb_store.append([mod, key, cmd])

    def _del_keybind(self, _w):
        sel = self._kb_view.get_selection()
        model, it = sel.get_selected()
        if it: model.remove(it)

    def _save_keybinds(self, path):
        try:
            import shutil as _sh; _sh.copy2(path, path+".bak")
            with open(path,"w") as f:
                f.writelines(self._kb_other)
                for row in self._kb_store:
                    f.write(WM.format_keybind(row[0],row[1],row[2]) + "\n")
            self._msg(f"Saved to {path}\n(backup: {path}.bak)")
        except Exception as e:
            self._msg(str(e), Gtk.MessageType.ERROR)

