#!/usr/bin/env python3
"""
essentials-theme-apply
Kills and restarts essentials-bars so the new theme takes effect live.
Called automatically by essentials-settings when the user switches themes.
"""
import subprocess, os, signal, time

BAR_BIN = os.path.expanduser("~/.local/bin/essentials-bars")

WIDGET_BIN = os.path.expanduser("~/.local/bin/essentials-widgets")

def _kill(name):
    try:
        out = subprocess.check_output(["pgrep", "-f", name], text=True)
        for pid in out.split():
            os.kill(int(pid), signal.SIGTERM)
    except subprocess.CalledProcessError:
        pass

def restart_bars():
    _kill("essentials-bars")
    time.sleep(0.4)
    subprocess.Popen(["python3", BAR_BIN],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    # Restart widgets if they were running
    try:
        subprocess.check_output(["pgrep", "-f", "essentials-widgets"], text=True)
        widgets_were_running = True
    except subprocess.CalledProcessError:
        widgets_were_running = False

    if widgets_were_running and os.path.exists(WIDGET_BIN):
        _kill("essentials-widgets")
        time.sleep(0.2)
        subprocess.Popen(["python3", WIDGET_BIN],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    DOCK_BIN = os.path.expanduser("~/.local/bin/essentials-dock")
    try:
        subprocess.check_output(["pgrep","-f","essentials-dock"], stderr=subprocess.DEVNULL)
        dock_was_running = True
    except subprocess.CalledProcessError:
        dock_was_running = False
    if dock_was_running and os.path.exists(DOCK_BIN):
        _kill("essentials-dock")
        time.sleep(0.2)
        subprocess.Popen(["python3", DOCK_BIN],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def apply_theme_to_wm():
    """Load active theme and apply WM borders via config-writer."""
    import importlib.util, json

    cw_path = os.path.expanduser("~/.local/bin/essentials-config-writer")
    if not os.path.exists(cw_path):
        return

    # Load config-writer module
    try:
        spec = importlib.util.spec_from_file_location("essentials_config_writer", cw_path)
        if not (spec and spec.loader): return
        cw = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(cw)
    except Exception as e:
        print(f"[theme-apply] config-writer load failed: {e}")
        return

    # Load active theme
    theme_path = os.path.expanduser("~/.config/essentials/themes.json")
    try:
        data  = json.load(open(theme_path))
        tname = data.get("current", "catppuccin")
        theme = data.get(tname, {})
    except Exception as e:
        print(f"[theme-apply] themes.json read failed: {e}")
        return

    # Detect compositor + config path via essentials-detect
    detect_path = os.path.expanduser("~/.local/bin/essentials-detect")
    wm_name, conf_path = "generic", None
    if os.path.exists(detect_path):
        try:
            spec2 = importlib.util.spec_from_file_location("essentials_detect", detect_path)
            if spec2 and spec2.loader:
                mod = importlib.util.module_from_spec(spec2)
                spec2.loader.exec_module(mod)
                wm      = mod.detect()
                wm_name = wm.name
                conf_path = wm.get_config_path()
        except Exception as e:
            print(f"[theme-apply] detect failed: {e}")

    ok, msg = cw.apply_wm_theme(wm_name, conf_path, theme)
    print(f"[theme-apply] WM borders: {'✓' if ok else '✗'} {msg}")


if __name__ == "__main__":
    apply_theme_to_wm()
    restart_bars()
