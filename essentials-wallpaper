#!/usr/bin/env python3
"""
essentials-wallpaper — Wallpaper manager with Wallhaven integration

Features:
  - Browse local wallpaper directories
  - Search and download from Wallhaven (api.wallhaven.cc)
  - Set wallpaper via swww / hyprpaper / swaybg / feh (auto-detected)
  - Generate a color theme from the current wallpaper (saved to themes.json)
  - Persists last wallpaper so it auto-restores on login

Wallhaven API key (optional, for NSFW/account searches):
  Set "wallhaven_apikey" in ~/.config/essentials/config.json
"""
import gi, os, json, subprocess, threading, shutil, colorsys, struct, zlib
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, GtkLayerShell, GLib, Gdk, GdkPixbuf
from urllib.request import urlopen, urlretrieve, Request
from urllib.parse   import urlencode
from urllib.error   import URLError

THEME_PATH  = os.path.expanduser("~/.config/essentials/themes.json")
CONFIG_PATH = os.path.expanduser("~/.config/essentials/config.json")
WALL_DIR    = os.path.expanduser("~/.config/essentials/wallpapers")
CACHE_DIR   = os.path.expanduser("~/.cache/essentials/wallhaven")
os.makedirs(WALL_DIR, exist_ok=True)
os.makedirs(CACHE_DIR, exist_ok=True)

def _load_config():
    try:
        with open(CONFIG_PATH) as f: return json.load(f)
    except: return {}

def _save_config(data):
    os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
    with open(CONFIG_PATH,"w") as f: json.dump(data,f,indent=4)

def _load_theme():
    try:
        data = json.load(open(THEME_PATH))
        cur  = data.get("current","catppuccin")
        return data.get(cur, data.get("catppuccin",{}))
    except:
        return {"bg":"rgba(17,17,27,0.92)","accent":"#cba6f7","text":"#cdd6f4","radius":"12px"}

T   = _load_theme()
CFG = _load_config()

def _run(*cmd, fallback=""):
    try:    return subprocess.check_output(list(cmd),text=True,stderr=subprocess.DEVNULL).strip()
    except: return fallback

# ── Wallpaper setters (auto-detect tool) ──────────────────────────────────────

def _detect_setter():
    for tool in ("swww","hyprpaper","swaybg","feh","wbg"):
        if shutil.which(tool): return tool
    return None

def set_wallpaper(path):
    tool = _detect_setter()
    if not tool:
        return False, "No wallpaper tool found (install swww, swaybg, hyprpaper, or feh)"
    path = os.path.abspath(path)
    try:
        if tool == "swww":
            # swww needs daemon running
            subprocess.Popen(["swww","init"], stderr=subprocess.DEVNULL)
            GLib.timeout_add(500, lambda: (
                subprocess.run(["swww","img",path,"--transition-type","wipe"],
                               stderr=subprocess.DEVNULL), False))
        elif tool == "swaybg":
            # Kill old instance
            subprocess.run(["pkill","swaybg"], stderr=subprocess.DEVNULL)
            subprocess.Popen(["swaybg","-i",path,"-m","fill"])
        elif tool == "hyprpaper":
            subprocess.run(["hyprctl","hyprpaper","preload",path], stderr=subprocess.DEVNULL)
            subprocess.run(["hyprctl","hyprpaper","wallpaper",f",{path}"], stderr=subprocess.DEVNULL)
        elif tool == "feh":
            subprocess.Popen(["feh","--bg-fill",path])
        elif tool == "wbg":
            subprocess.run(["pkill","wbg"], stderr=subprocess.DEVNULL)
            subprocess.Popen(["wbg",path])

        # Persist
        cfg = _load_config()
        cfg["wallpaper"] = path
        _save_config(cfg)
        return True, f"Set via {tool}"
    except Exception as e:
        return False, str(e)

def restore_wallpaper():
    cfg  = _load_config()
    wall = cfg.get("wallpaper")
    if wall and os.path.exists(wall):
        set_wallpaper(wall)

# ── Color extraction from image (PIL) ────────────────────────────────────────

def _extract_palette(path, n_colors=8):
    """Extract dominant colours from an image using PIL quantize."""
    try:
        from PIL import Image
        img    = Image.open(path).convert("RGB")
        img.thumbnail((200,200))
        quant  = img.quantize(colors=n_colors, method=Image.Quantize.FASTOCTREE)
        pal    = quant.getpalette()[:n_colors*3]
        colors = [(pal[i],pal[i+1],pal[i+2]) for i in range(0,len(pal),3)]
        # Sort by saturation descending to get vivid colours first
        def sat(c):
            r,g,b = [x/255 for x in c]
            h,s,v = colorsys.rgb_to_hsv(r,g,b)
            return s
        return sorted(colors, key=sat, reverse=True)
    except Exception as e:
        print(f"[wallpaper] palette extraction failed: {e}")
        return []

def generate_theme_from_wallpaper(path, theme_name="wallpaper"):
    """Generate a theme dict from the wallpaper and save it to themes.json."""
    colors = _extract_palette(path)
    if not colors:
        return None, "Could not extract colours (PIL required)"

    def _hex(c): return "#{:02x}{:02x}{:02x}".format(*c)
    def _dark(c, factor=0.15):
        r,g,b = [x/255 for x in c]
        h,s,v = colorsys.rgb_to_hsv(r,g,b)
        v2     = max(0.05, v*factor)
        r2,g2,b2 = colorsys.hsv_to_rgb(h,s,v2)
        return (int(r2*255),int(g2*255),int(b2*255))

    # accent = most saturated colour
    # bg     = very dark version of that hue
    # text   = near-white
    accent_rgb = colors[0]
    bg_rgb     = _dark(accent_rgb, 0.12)
    text_rgb   = (220, 220, 230)

    theme = {
        "bg":     f"rgba({bg_rgb[0]},{bg_rgb[1]},{bg_rgb[2]},0.92)",
        "accent": _hex(accent_rgb),
        "text":   _hex(text_rgb),
        "radius": "12px",
        "font":   "JetBrainsMono Nerd Font",
    }

    try:
        data = json.load(open(THEME_PATH)) if os.path.exists(THEME_PATH) else {}
        data[theme_name] = theme
        with open(THEME_PATH,"w") as f: json.dump(data,f,indent=4)
    except Exception as e:
        return None, str(e)

    return theme, f"Theme '{theme_name}' generated and saved."

# ── Wallhaven API ─────────────────────────────────────────────────────────────

WALLHAVEN_SEARCH = "https://wallhaven.cc/api/v1/search"
WALLHAVEN_INFO   = "https://wallhaven.cc/api/v1/w/{id}"
THUMB_SIZE       = (320, 180)

def _wh_search(query, page=1, categories="110", purity="100", sorting="relevance"):
    params = {"q":query,"page":page,"categories":categories,
              "purity":purity,"sorting":sorting,"atleast":"1920x1080"}
    apikey = CFG.get("wallhaven_apikey","")
    if apikey: params["apikey"] = apikey
    url = f"{WALLHAVEN_SEARCH}?{urlencode(params)}"
    try:
        req  = Request(url, headers={"User-Agent":"essentials-shell/1.0"})
        data = json.loads(urlopen(req, timeout=10).read())
        return data.get("data",[])
    except Exception as e:
        print(f"[wallhaven] search failed: {e}")
        return []

def _wh_download(thumb_url, full_url, wh_id):
    """Download thumbnail to cache, return local path."""
    thumb_path = os.path.join(CACHE_DIR, f"{wh_id}_thumb.jpg")
    if not os.path.exists(thumb_path):
        try:
            req = Request(thumb_url, headers={"User-Agent":"essentials-shell/1.0"})
            data = urlopen(req, timeout=8).read()
            with open(thumb_path,"wb") as f: f.write(data)
        except Exception as e:
            print(f"[wallhaven] thumb download failed: {e}")
            return None
    return thumb_path

def _wh_download_full(full_url, wh_id):
    """Download full-resolution wallpaper to WALL_DIR."""
    ext  = full_url.rsplit(".",1)[-1]
    path = os.path.join(WALL_DIR, f"wallhaven_{wh_id}.{ext}")
    if os.path.exists(path): return path
    try:
        req = Request(full_url, headers={"User-Agent":"essentials-shell/1.0"})
        data = urlopen(req, timeout=30).read()
        with open(path,"wb") as f: f.write(data)
        return path
    except Exception as e:
        print(f"[wallhaven] full download failed: {e}")
        return None

