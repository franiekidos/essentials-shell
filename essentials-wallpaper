    def _browse_dir(self, _):
        dlg = Gtk.FileChooserDialog(title="Choose wallpaper directory",
            parent=self, action=Gtk.FileChooserAction.SELECT_FOLDER)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Open", Gtk.ResponseType.OK)
        if dlg.run() == Gtk.ResponseType.OK:
            self._dir_entry.set_text(dlg.get_filename())
            self._scan_local()
        dlg.destroy()

    def _scan_local(self):
        for c in self._local_flow.get_children(): self._local_flow.remove(c)
        d    = self._dir_entry.get_text()
        exts = {".jpg",".jpeg",".png",".webp",".gif"}
        try:
            files = [os.path.join(d,f) for f in sorted(os.listdir(d))
                     if os.path.splitext(f)[1].lower() in exts]
        except: files = []
        self._local_status.set_text(f"{len(files)} wallpapers found")
        for path in files:
            GLib.idle_add(self._add_local_thumb, path)
        return False

    def _add_local_thumb(self, path):
        try:
            pb = GdkPixbuf.Pixbuf.new_from_file_at_scale(path, 220, 124, True)
            img  = Gtk.Image.new_from_pixbuf(pb)
            btn  = Gtk.Button(); btn.set_name("thumb-btn")
            vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            vbox.pack_start(img, False, False, 0)
            name_lbl = Gtk.Label(label=os.path.basename(path)[:22])
            name_lbl.set_name("thumb-lbl")
            vbox.pack_start(name_lbl, False, False, 0)
            btn.add(vbox)
            btn.connect("clicked", lambda _, p=path: self._preview_select(p, "local"))
            btn.set_tooltip_text(path)
            self._local_flow.add(btn)
            self._local_flow.show_all()
        except Exception as e:
            print(f"[wallpaper] thumb failed {path}: {e}")
        return False

    def _preview_select(self, path, source):
        self._selected_path   = path
        self._selected_source = source

    def _set_local(self, _):
        path = getattr(self,"_selected_path", None)
        if not path:
            self._local_status.set_text("Select a wallpaper first")
            return
        ok, msg = set_wallpaper(path)
        self._local_status.set_markup(
            f"<span foreground='{'#a6e3a1' if ok else '#f38ba8'}'>{'✓' if ok else '✗'} {msg}</span>")

    def _gen_theme_local(self, _):
        path = getattr(self,"_selected_path", None)
        if not path:
            self._local_status.set_text("Select a wallpaper first")
            return
        self._local_status.set_text("Generating theme…")
        def _do():
            theme, msg = generate_theme_from_wallpaper(path)
            GLib.idle_add(lambda: (self._local_status.set_markup(
                f"<span foreground='{'#a6e3a1' if theme else '#f38ba8'}'>{'✓' if theme else '✗'} {msg}</span>"), False))
        threading.Thread(target=_do, daemon=True).start()

    # ── Wallhaven tab ─────────────────────────────────────────────────────────
