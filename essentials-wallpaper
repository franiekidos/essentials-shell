    def _wh_search_go(self, _=None):
        q = self._wh_entry.get_text().strip()
        if not q: return
        self._wh_status.set_text(f"Searching for '{q}'…")
        for c in self._wh_flow.get_children(): self._wh_flow.remove(c)
        sort = self._wh_sort.get_active_text() or "relevance"
        def _search():
            results = _wh_search(q, sorting=sort)
            self._current_results = results
            GLib.idle_add(lambda: (
                self._wh_status.set_text(f"{len(results)} results"),
                [GLib.idle_add(self._add_wh_thumb, r) for r in results[:24]],
                False))
        threading.Thread(target=_search, daemon=True).start()

    def _add_wh_thumb(self, result):
        wh_id     = result.get("id","")
        thumb_url = result.get("thumbs",{}).get("small","")
        full_url  = result.get("path","")
        res       = result.get("resolution","")
        def _fetch():
            path = _wh_download(thumb_url, full_url, wh_id)
            if path:
                GLib.idle_add(self._add_wh_thumb_widget, path, full_url, wh_id, res)
        threading.Thread(target=_fetch, daemon=True).start()
        return False

    def _add_wh_thumb_widget(self, thumb_path, full_url, wh_id, res):
        try:
            pb   = GdkPixbuf.Pixbuf.new_from_file_at_scale(thumb_path, 220, 124, True)
            img  = Gtk.Image.new_from_pixbuf(pb)
            btn  = Gtk.Button(); btn.set_name("thumb-btn")
            vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            vbox.pack_start(img, False, False, 0)
            lbl = Gtk.Label(label=res); lbl.set_name("thumb-lbl")
            vbox.pack_start(lbl, False, False, 0)
            btn.add(vbox)
            btn.connect("clicked", lambda _, u=full_url, i=wh_id, t=thumb_path:
                        self._wh_select(u, i, t))
            self._wh_flow.add(btn); self._wh_flow.show_all()
        except Exception as e:
            print(f"[wallhaven] widget failed: {e}")
        return False

    def _wh_select(self, full_url, wh_id, thumb_path):
        self._selected_path   = thumb_path   # use thumb for theme gen preview
        self._selected_wh_url = full_url
        self._selected_wh_id  = wh_id
        self._selected_source = "wallhaven"
        self._wh_status.set_text(f"Selected: {wh_id}  ({full_url.rsplit('/',1)[-1]})")

    def _wh_download_set(self, _):
        url  = getattr(self,"_selected_wh_url", None)
        wid  = getattr(self,"_selected_wh_id",  None)
        if not url:
            self._wh_status.set_text("Select a wallpaper first")
            return
        self._wh_status.set_text("Downloading…")
        def _dl():
            path = _wh_download_full(url, wid)
            if path:
                ok, msg = set_wallpaper(path)
                GLib.idle_add(lambda: (self._wh_status.set_markup(
                    f"<span foreground='{'#a6e3a1' if ok else '#f38ba8'}'>{'✓' if ok else '✗'} {msg}</span>"), False))
                self._selected_path = path
            else:
                GLib.idle_add(lambda: (self._wh_status.set_markup(
                    "<span foreground='#f38ba8'>✗ Download failed</span>"), False))
        threading.Thread(target=_dl, daemon=True).start()

    def _gen_theme_wh(self, _):
        path = getattr(self,"_selected_path", None)
        if not path:
            self._wh_status.set_text("Select a wallpaper first")
            return
        self._wh_status.set_text("Generating theme from wallpaper colours…")
        def _do():
            theme, msg = generate_theme_from_wallpaper(path, "wallpaper")
            GLib.idle_add(lambda: (self._wh_status.set_markup(
                f"<span foreground='{'#a6e3a1' if theme else '#f38ba8'}'>{'✓' if theme else '✗'} {msg}</span>"), False))
        threading.Thread(target=_do, daemon=True).start()

