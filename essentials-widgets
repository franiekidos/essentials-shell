# ── Launch enabled widgets ────────────────────────────────────────────────────
enabled = WIDGET_CFG.get("enabled", ["clock"])
widget_map = {"clock":ClockWidget, "sysinfo":SysinfoWidget, "media":MediaWidget}
for name in enabled:
    if name == "weather":
        # Weather desktop widget loaded from essentials-weather
        try:
            import importlib.util as _iu, os as _os
            _path = _os.path.expanduser("~/.local/bin/essentials-weather")
            if _os.path.exists(_path):
                loader = importlib.machinery.SourceFileLoader("essentials_weather", _path)
                spec   = importlib.util.spec_from_loader("essentials_weather", loader)
                mod    = importlib.util.module_from_spec(spec)
                loader.exec_module(mod)
                mod = _iu.module_from_spec(spec); spec.loader.exec_module(mod)
                _wcfg = WIDGET_CFG.get("weather",{})
                corner = _wcfg.get("corner","bottom-center")
                class WeatherDesktopWidget(BaseWidget):
                    def __init__(self):
                        super().__init__(corner=corner, margin=_wcfg.get("margin",48))
                        self.add(mod.make_desktop_widget()); self.show_all()
                WeatherDesktopWidget()
        except Exception as e:
            print(f"[widgets] weather failed: {e}")
        continue
    cls = widget_map.get(name)
    if cls:
        try: cls()
        except Exception as e: print(f"[widgets] {name} failed: {e}")

Gtk.main()
